<!-- Scroll to top -->
<button class="scroll-top" id="scrollTop" aria-label="Scroll to top"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18"/></svg></button>

<script>
  // ── Mobile menu ──────────────────────────
  const ham = document.getElementById('hamburger');
  const mob = document.getElementById('mobileMenu');
  ham.addEventListener('click', () => { ham.classList.toggle('open'); mob.classList.toggle('open'); });
  document.querySelectorAll('.mobile-menu a').forEach(a => a.addEventListener('click', () => { ham.classList.remove('open'); mob.classList.remove('open'); }));

  // ── Scroll reveal ────────────────────────
  const io = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); io.unobserve(e.target); } });
  }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
  document.querySelectorAll('.reveal').forEach(el => io.observe(el));

  // ── Scroll top ───────────────────────────
  const st = document.getElementById('scrollTop');
  window.addEventListener('scroll', () => { st.classList.toggle('show', window.scrollY > 400); });
  st.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));

  // ── Header shrink ────────────────────────
  window.addEventListener('scroll', () => {
    document.querySelector('header').style.background = window.scrollY > 40 ? 'rgba(6,11,20,0.95)' : 'rgba(6,11,20,0.82)';
  });

  // ── Contact form ─────────────────────────
  document.getElementById('contactForm').addEventListener('submit', function(e) {
    e.preventDefault();
    const btn = this.querySelector('.cf-submit');
    btn.innerHTML = '<svg class="spin" width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg> Sending…';
    btn.disabled = true;
    setTimeout(() => {
      btn.innerHTML = '<svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg> Sent!';
      btn.style.background = 'linear-gradient(135deg,#10b981,#0ea5e9)';
      this.reset();
      setTimeout(() => { btn.innerHTML = 'Send Message <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>'; btn.style.background=''; btn.disabled=false; }, 2500);
    }, 1000);
  });

  // ── Recent bots from localStorage ────────
  const bots = JSON.parse(localStorage.getItem('vc_bots') || '[]');
  if (bots.length) {
    const sec = document.getElementById('recentBotsSection');
    if (sec) {
      sec.classList.remove('hidden');
      const list = document.getElementById('recentBotsList');
      if (list) list.innerHTML = bots.slice(-3).reverse().map(b=>`<div style="display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:1px solid var(--border)"><div style="width:32px;height:32px;border-radius:8px;background:rgba(56,189,248,.1);display:flex;align-items:center;justify-content:center;flex-shrink:0"><svg width="15" height="15" fill="none" stroke="#38bdf8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg></div><div><div style="font-size:13px;color:var(--text);font-weight:500">${b.name}</div><div style="font-size:11px;color:var(--text-3)">${new Date(b.savedAt).toLocaleDateString()}</div></div></div>`).join('');
    }
  }

  // Spin keyframe
  const style = document.createElement('style');
  style.textContent = '@keyframes spin{to{transform:rotate(360deg)}} .spin{animation:spin .7s linear infinite}';
  document.head.appendChild(style);
</script>
</body>
</html>