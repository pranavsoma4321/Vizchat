    .contact-form { background: var(--s2); border: 1px solid var(--border); border-radius: 20px; padding: 32px; position: relative; overflow: hidden; }
    .contact-form::before { content: ''; position: absolute; top: 0; left: 20%; right: 20%; height: 1px; background: linear-gradient(90deg, transparent, rgba(236,72,153,.4), transparent); }
