<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>VizChat — AI Chatbot Builder</title>
  <meta name="description" content="Build conversational and data-driven chatbots with a modern UI, fast setup, and local-first privacy.">
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --sky: #38bdf8; --sky-dark: #0ea5e9; --indigo: #6366f1; --indigo-mid: #4f46e5;
      --emerald: #10b981; --pink: #ec4899; --amber: #f59e0b; --purple: #a78bfa;
      --surface: #060b14; --s2: #0b1019; --s3: #101620; --s4: #161e2e;
      --border: rgba(255,255,255,0.07); --border-mid: rgba(255,255,255,0.12);
      --text: #eef5ff; --text-2: #7a90b4; --text-3: #3b4f6e;
    }

    html { scroll-behavior: smooth; }
    body { background: var(--surface); color: var(--text); font-family: 'DM Sans', sans-serif; font-size: 15px; -webkit-font-smoothing: antialiased; overflow-x: hidden; }

    /* ── BG layers ── */
    .bg-mesh {
      position: fixed; inset: 0; z-index: 0; pointer-events: none;
      background:
        radial-gradient(ellipse 60% 50% at 10% 90%, rgba(56,189,248,0.08) 0%, transparent 55%),
        radial-gradient(ellipse 55% 45% at 92% 5%,  rgba(99,102,241,0.10) 0%, transparent 55%),
        radial-gradient(ellipse 40% 35% at 50% 50%, rgba(236,72,153,0.04) 0%, transparent 55%);
    }

    .bg-grid {
      position: fixed; inset: 0; z-index: 0; pointer-events: none;
      background-image: linear-gradient(rgba(255,255,255,0.016) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.016) 1px, transparent 1px);
      background-size: 56px 56px;
      mask-image: radial-gradient(ellipse 80% 80% at 50% 40%, black 20%, transparent 80%);
    }

    /* ── Typography ── */
    .display { font-family: 'Syne', sans-serif; font-weight: 800; letter-spacing: -.04em; line-height: 1.05; }
    .heading { font-family: 'Syne', sans-serif; font-weight: 700; letter-spacing: -.03em; }
    .label { font-size: 11px; font-weight: 500; letter-spacing: .08em; text-transform: uppercase; }

    /* ── Header ── */
    header {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      background: rgba(6,11,20,0.82); backdrop-filter: blur(20px) saturate(180%);
      border-bottom: 1px solid var(--border);
    }

    .hdr { max-width: 1280px; margin: 0 auto; padding: 0 24px; height: 64px; display: flex; align-items: center; justify-content: space-between; }

    .logo { display: flex; align-items: center; gap: 10px; text-decoration: none; }
    .logo-box { width: 36px; height: 36px; background: linear-gradient(135deg, var(--sky-dark), var(--indigo-mid)); border-radius: 10px; display: flex; align-items: center; justify-content: center; box-shadow: 0 0 0 1px rgba(56,189,248,0.2), 0 6px 18px rgba(14,165,233,0.18); flex-shrink: 0; }
    .logo-box svg { width: 18px; height: 18px; color: #fff; }
    .logo-name { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 20px; letter-spacing: -.03em; color: var(--text); }
    .logo-name span { color: var(--sky); }

    nav { display: flex; align-items: center; gap: 6px; }
    .nav-link { padding: 7px 13px; border-radius: 8px; font-size: 13px; color: var(--text-2); text-decoration: none; transition: all .2s; }
    .nav-link:hover { color: var(--text); background: rgba(255,255,255,0.05); }

    .hdr-actions { display: flex; align-items: center; gap: 8px; }
    .btn-pill { padding: 5px 12px; border-radius: 8px; font-family: 'DM Sans', sans-serif; font-size: 12px; font-weight: 500; text-decoration: none; cursor: pointer; border: none; transition: all .2s; display: inline-flex; align-items: center; gap: 5px; }
    .btn-xs { padding: 3px 8px; font-size: 11px; }
    .btn-lg { padding: 7px 16px; font-size: 14px; }
    .btn-ghost { color: var(--text-2); background: rgba(255,255,255,0.05); border: 1px solid var(--border); }
    .btn-ghost:hover { color: var(--text); background: rgba(255,255,255,0.09); }
    .btn-primary { background: linear-gradient(135deg, var(--sky-dark), var(--indigo-mid)); color: #fff; box-shadow: 0 4px 16px rgba(14,165,233,0.2); }
    .btn-primary:hover { opacity: .9; transform: translateY(-1px); box-shadow: 0 6px 22px rgba(14,165,233,0.28); }

    /* Mobile hamburger */
    .hamburger { display: none; flex-direction: column; gap: 5px; cursor: pointer; padding: 6px; border: none; background: none; }
    .hamburger span { display: block; width: 22px; height: 2px; background: var(--text-2); border-radius: 1px; transition: all .25s; }
    .hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    .hamburger.open span:nth-child(2) { opacity: 0; }
    .hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

    .mobile-menu { display: none; position: absolute; top: 100%; left: 0; right: 0; background: rgba(6,11,20,0.97); backdrop-filter: blur(20px); border-bottom: 1px solid var(--border); padding: 16px 24px 20px; }
    .mobile-menu.open { display: block; }
    .mobile-menu a { display: block; padding: 11px 14px; border-radius: 9px; color: var(--text-2); text-decoration: none; font-size: 14px; transition: all .2s; }
    .mobile-menu a:hover { color: var(--text); background: rgba(255,255,255,0.06); }
    .mobile-menu .divider { height: 1px; background: var(--border); margin: 10px 0; }

    @media(max-width:900px) { nav { display: none; } .hamburger { display: flex; } .hdr-actions .btn-primary { display: none; } }
    @media(max-width:600px) { .hdr-actions .btn-ghost { display: none; } }

    /* ── Sections ── */
    section { position: relative; z-index: 1; }
    .wrap { max-width: 1280px; margin: 0 auto; padding: 0 24px; }

    /* scroll reveal */
    .reveal { opacity: 0; transform: translateY(22px); transition: opacity .6s ease, transform .6s ease; }
    .reveal.visible { opacity: 1; transform: translateY(0); }

    /* ── HERO ── */
    #hero { min-height: 100vh; display: flex; align-items: center; padding: 100px 0 60px; }

    .hero-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; }
    @media(max-width:900px){ .hero-grid{grid-template-columns:1fr; gap:40px;} }

    .eyebrow { display: inline-flex; align-items: center; gap: 7px; padding: 5px 12px; border-radius: 100px; background: rgba(56,189,248,0.08); border: 1px solid rgba(56,189,248,0.18); margin-bottom: 20px; }
    .eyebrow-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--sky); animation: pulse-dot 2s ease infinite; }
    .eyebrow-txt { font-size: 11px; color: var(--sky); font-weight: 500; letter-spacing: .06em; text-transform: uppercase; }
    @keyframes pulse-dot { 0%,100%{opacity:1} 50%{opacity:.3} }

    .hero-title { font-family: 'Syne', sans-serif; font-weight: 800; font-size: clamp(36px, 5.5vw, 62px); letter-spacing: -.04em; line-height: 1.05; color: var(--text); margin-bottom: 18px; }
    .hero-title .accent { background: linear-gradient(135deg, var(--sky) 20%, var(--indigo) 80%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
    .hero-title .accent-green { background: linear-gradient(135deg, var(--emerald), var(--sky)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }

    .hero-sub { font-size: 16px; color: var(--text-2); line-height: 1.7; max-width: 460px; margin-bottom: 32px; font-weight: 300; }

    .hero-ctas { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 36px; }
    .btn-large { padding: 13px 24px; border-radius: 11px; font-family: 'DM Sans', sans-serif; font-size: 14px; font-weight: 500; text-decoration: none; display: inline-flex; align-items: center; gap: 7px; transition: all .2s; cursor: pointer; border: none; }
    .btn-large svg { width: 15px; height: 15px; }
    .bl-primary { background: linear-gradient(135deg, var(--sky-dark), var(--indigo-mid)); color: #fff; position: relative; overflow: hidden; box-shadow: 0 4px 20px rgba(14,165,233,0.22); }
    .bl-primary:hover { opacity: .9; transform: translateY(-2px); box-shadow: 0 8px 28px rgba(14,165,233,0.32); }
    .bl-primary .shine { position: absolute; top: 0; left: -100%; width: 55%; height: 100%; background: linear-gradient(90deg, transparent, rgba(255,255,255,.15), transparent); transition: left .6s; }
    .bl-primary:hover .shine { left: 160%; }
    .bl-outline { background: rgba(255,255,255,0.04); color: var(--text); border: 1px solid var(--border-mid); }
    .bl-outline:hover { background: rgba(255,255,255,0.08); border-color: rgba(255,255,255,0.2); }

    /* Trust pills */
    .trust-row { display: flex; flex-wrap: wrap; gap: 8px; }
    .trust-pill { display: flex; align-items: center; gap: 6px; padding: 5px 11px; border-radius: 7px; background: rgba(255,255,255,0.03); border: 1px solid var(--border); font-size: 12px; color: var(--text-3); }
    .trust-pill svg { width: 12px; height: 12px; color: var(--emerald); }

    /* Chat mockup */
    .chat-mockup { position: relative; }
    .chat-mockup::before { content: ''; position: absolute; inset: -40px; background: radial-gradient(ellipse 70% 60% at 50% 50%, rgba(56,189,248,0.12) 0%, transparent 65%); pointer-events: none; border-radius: 50%; }
    .chat-window { background: var(--s2); border: 1px solid var(--border); border-radius: 18px; overflow: hidden; position: relative; }
    .chat-titlebar { display: flex; align-items: center; gap: 7px; padding: 14px 16px; border-bottom: 1px solid var(--border); background: var(--s3); }
    .tbar-dots { display: flex; gap: 5px; }
    .tbar-dot { width: 9px; height: 9px; border-radius: 50%; }
    .td-r{background:#ff5f57} .td-y{background:#ffbd2e} .td-g{background:#28c840}
    .tbar-title { font-size: 12px; color: var(--text-3); margin-left: auto; }
    .chat-body { padding: 16px; display: flex; flex-direction: column; gap: 10px; }
    .cm { padding: 10px 13px; border-radius: 10px; font-size: 13px; line-height: 1.5; max-width: 88%; }
    .cm-bot { background: rgba(56,189,248,0.07); border: 1px solid rgba(56,189,248,0.14); color: var(--text); }
    .cm-bot .cl { font-size: 10px; color: var(--sky); font-weight: 500; display: block; margin-bottom: 3px; }
    .cm-user { background: rgba(255,255,255,0.05); border: 1px solid var(--border); color: var(--text-2); align-self: flex-end; }
    .typing-row { display: flex; gap: 4px; align-items: center; padding: 10px 14px; background: rgba(56,189,248,0.05); border: 1px solid rgba(56,189,248,0.1); border-radius: 10px; width: fit-content; }
    .td2 { width: 5px; height: 5px; border-radius: 50%; background: var(--sky); animation: bounce2 1.2s infinite; }
    .td2:nth-child(2){animation-delay:.2s} .td2:nth-child(3){animation-delay:.4s}
    @keyframes bounce2{0%,60%,100%{transform:translateY(0);opacity:.3}30%{transform:translateY(-4px);opacity:1}}

    /* Tech tags in mockup */
    .tech-row { display: flex; gap: 5px; margin-top: 6px; flex-wrap: wrap; }
    .tech-tag { padding: 2px 7px; border-radius: 4px; font-size: 10px; font-weight: 500; letter-spacing: .04em; }
    .tt-sky { background: rgba(56,189,248,.1); color: #7dd3fc; border: 1px solid rgba(56,189,248,.18); }
    .tt-green { background: rgba(16,185,129,.1); color: #6ee7b7; border: 1px solid rgba(16,185,129,.18); }
    .tt-purple { background: rgba(167,139,250,.1); color: #c4b5fd; border: 1px solid rgba(167,139,250,.18); }

    /* Floating cards */
    .float-cards { display: flex; flex-direction: column; gap: 8px; margin-top: 10px; }
    .float-card { display: flex; align-items: center; gap: 10px; padding: 10px 13px; background: var(--s3); border: 1px solid var(--border); border-radius: 10px; font-size: 12px; animation: float-anim ease-in-out infinite; }
    .float-card:nth-child(2) { animation-delay: -2s; }
    .float-card:nth-child(3) { animation-delay: -4s; }
    @keyframes float-anim { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-4px)} }
    .fc-icon { width: 28px; height: 28px; border-radius: 7px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .fc-icon svg { width: 14px; height: 14px; }
    .fci-sky { background: rgba(56,189,248,.1); color: var(--sky); }
    .fci-green { background: rgba(16,185,129,.1); color: var(--emerald); }
    .fci-purple { background: rgba(167,139,250,.1); color: var(--purple); }
    .fc-label { color: var(--text-2); }
    .fc-label strong { color: var(--text); display: block; font-size: 12px; font-weight: 500; }

    /* ── STATS ── */
    #stats { padding: 0; margin: 0 0 -1px; }
    .stats-band { border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); background: var(--s2); padding: 28px 0; }
    .stats-inner { display: grid; grid-template-columns: repeat(4,1fr); divide: var(--border); }
    @media(max-width:700px){ .stats-inner{grid-template-columns:repeat(2,1fr)} }
    .stat-item { text-align: center; padding: 10px 20px; border-right: 1px solid var(--border); }
    .stat-item:last-child { border-right: none; }
    @media(max-width:700px){ .stat-item:nth-child(2){border-right:none} .stat-item:nth-child(3){border-top:1px solid var(--border)} .stat-item:nth-child(4){border-top:1px solid var(--border);border-right:none} }
    .stat-num { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 28px; letter-spacing: -.03em; color: var(--text); }
    .stat-lbl { font-size: 12px; color: var(--text-3); margin-top: 3px; }

    /* ── HOW IT WORKS ── */
    #how { padding: 100px 0; }
    .sec-eyebrow { display: inline-flex; align-items: center; gap: 7px; padding: 5px 12px; border-radius: 100px; font-size: 11px; font-weight: 500; letter-spacing: .06em; text-transform: uppercase; margin-bottom: 14px; }
    .sec-title { font-family: 'Syne', sans-serif; font-weight: 700; font-size: clamp(26px, 3.5vw, 40px); letter-spacing: -.03em; color: var(--text); margin-bottom: 14px; }
    .sec-sub { font-size: 15px; color: var(--text-2); line-height: 1.7; max-width: 520px; font-weight: 300; }

    .steps-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 20px; margin-top: 52px; position: relative; }
    @media(max-width:800px){ .steps-grid{grid-template-columns:1fr} }

    .step-connector { position: absolute; top: 52px; left: calc(33.33% - 10px); width: calc(33.33% + 20px); height: 1px; background: linear-gradient(90deg, rgba(99,102,241,.3), rgba(236,72,153,.3)); display: none; }
    @media(min-width:800px){ .step-connector{display:block;} }
    .step-connector-2 { left: calc(66.66% - 10px); }

    .step-card { background: var(--s2); border: 1px solid var(--border); border-radius: 18px; padding: 28px 24px; position: relative; overflow: hidden; transition: border-color .25s, transform .25s; cursor: default; text-decoration: none; display: block; }
    .step-card:hover { border-color: var(--border-mid); transform: translateY(-4px); }
    .step-card::before { content: ''; position: absolute; inset: 0; opacity: 0; transition: opacity .3s; border-radius: 18px; }
    .sc-purple::before { background: radial-gradient(ellipse 80% 60% at 50% 0%, rgba(99,102,241,0.06) 0%, transparent 70%); }
    .sc-pink::before   { background: radial-gradient(ellipse 80% 60% at 50% 0%, rgba(236,72,153,0.06) 0%, transparent 70%); }
    .sc-violet::before { background: radial-gradient(ellipse 80% 60% at 50% 0%, rgba(167,139,250,0.06) 0%, transparent 70%); }
    .step-card:hover::before { opacity: 1; }

    .step-num { width: 42px; height: 42px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-family: 'Syne', sans-serif; font-weight: 700; font-size: 18px; margin-bottom: 20px; position: relative; }
    .sn-purple { background: rgba(99,102,241,.1); color: #a5b4fc; border: 1px solid rgba(99,102,241,.2); }
    .sn-pink   { background: rgba(236,72,153,.1); color: #f9a8d4; border: 1px solid rgba(236,72,153,.2); }
    .sn-violet { background: rgba(167,139,250,.1); color: #c4b5fd; border: 1px solid rgba(167,139,250,.2); }

    .step-icon { width: 44px; height: 44px; border-radius: 12px; display: flex; align-items: center; justify-content: center; margin-bottom: 16px; }
    .step-icon svg { width: 22px; height: 22px; }
    .si-purple { background: rgba(99,102,241,.1); color: #a5b4fc; }
    .si-pink   { background: rgba(236,72,153,.1); color: #f9a8d4; }
    .si-violet { background: rgba(167,139,250,.1); color: #c4b5fd; }

    .step-title { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 17px; color: var(--text); margin-bottom: 8px; }
    .step-desc { font-size: 13px; color: var(--text-2); line-height: 1.65; margin-bottom: 16px; }
    .step-bullets { display: flex; flex-direction: column; gap: 6px; }
    .sbullet { display: flex; align-items: center; gap: 7px; font-size: 12px; color: var(--text-3); }
    .sbullet-dot { width: 5px; height: 5px; border-radius: 50%; flex-shrink: 0; }
    .bd-purple { background: #a5b4fc; } .bd-pink { background: #f9a8d4; } .bd-violet { background: #c4b5fd; }

    .step-cta { display: flex; align-items: center; gap: 5px; font-size: 12px; font-weight: 500; margin-top: 20px; padding-top: 16px; border-top: 1px solid var(--border); transition: gap .2s; }
    .step-cta svg { width: 13px; height: 13px; transition: transform .2s; }
    .step-card:hover .step-cta { gap: 8px; }
    .step-card:hover .step-cta svg { transform: translateX(3px); }
    .ctc-purple { color: #a5b4fc; } .ctc-pink { color: #f9a8d4; } .ctc-violet { color: #c4b5fd; }

    /* ── SERVICES ── */
    #services { padding: 100px 0; background: linear-gradient(to bottom, transparent, rgba(11,16,25,0.6) 30%, rgba(11,16,25,0.6) 70%, transparent); }

    .services-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 18px; margin-top: 52px; }
    @media(max-width:900px){ .services-grid{grid-template-columns:1fr} }

    .svc-card { background: var(--s2); border: 1px solid var(--border); border-radius: 18px; padding: 28px; display: flex; flex-direction: column; transition: all .25s; position: relative; overflow: hidden; }
    .svc-card:hover { transform: translateY(-5px); border-color: var(--border-mid); }
    .svc-glow { position: absolute; inset: 0; opacity: 0; transition: opacity .3s; border-radius: 18px; pointer-events: none; }
    .sg-sky    { background: radial-gradient(ellipse 80% 50% at 50% -10%, rgba(56,189,248,0.08) 0%, transparent 70%); }
    .sg-violet { background: radial-gradient(ellipse 80% 50% at 50% -10%, rgba(167,139,250,0.08) 0%, transparent 70%); }
    .sg-green  { background: radial-gradient(ellipse 80% 50% at 50% -10%, rgba(16,185,129,0.08) 0%, transparent 70%); }
    .svc-card:hover .svc-glow { opacity: 1; }

    .svc-icon { width: 52px; height: 52px; border-radius: 14px; display: flex; align-items: center; justify-content: center; margin-bottom: 20px; transition: transform .25s; }
    .svc-card:hover .svc-icon { transform: scale(1.08); }
    .svc-icon svg { width: 26px; height: 26px; }
    .svi-sky    { background: rgba(56,189,248,.1);  color: var(--sky); }
    .svi-violet { background: rgba(167,139,250,.1); color: var(--purple); }
    .svi-green  { background: rgba(16,185,129,.1);  color: var(--emerald); }

    .svc-title { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 17px; color: var(--text); margin-bottom: 8px; }
    .svc-desc { font-size: 13px; color: var(--text-2); line-height: 1.65; margin-bottom: 20px; flex: 1; }
    .svc-features { display: flex; flex-direction: column; gap: 6px; margin-bottom: 20px; }
    .svc-feat { display: flex; align-items: center; gap: 8px; font-size: 12px; color: var(--text-3); }
    .svc-feat svg { width: 12px; height: 12px; flex-shrink: 0; }
    .sf-sky    { color: var(--sky); } .sf-violet { color: var(--purple); } .sf-green { color: var(--emerald); }

    .svc-btn { display: flex; align-items: center; justify-content: center; gap: 7px; padding: 11px; border-radius: 10px; font-size: 13px; font-weight: 500; text-decoration: none; transition: all .2s; }
    .svc-btn svg { width: 14px; height: 14px; transition: transform .2s; }
    .svc-card:hover .svc-btn svg { transform: translateX(3px); }
    .svb-sky    { background: rgba(56,189,248,.08);  color: #7dd3fc; border: 1px solid rgba(56,189,248,.18); }
    .svb-sky:hover    { background: rgba(56,189,248,.15); }
    .svb-violet { background: rgba(167,139,250,.08); color: #c4b5fd; border: 1px solid rgba(167,139,250,.18); }
    .svb-violet:hover { background: rgba(167,139,250,.15); }
    .svb-green  { background: rgba(16,185,129,.08);  color: #6ee7b7; border: 1px solid rgba(16,185,129,.18); }
    .svb-green:hover  { background: rgba(16,185,129,.15); }

    .coming-soon { position: absolute; top: 16px; right: 16px; padding: 3px 9px; border-radius: 5px; background: rgba(245,158,11,.1); color: #fcd34d; border: 1px solid rgba(245,158,11,.2); font-size: 10px; font-weight: 500; letter-spacing: .04em; }

    /* ── WHY SECTION ── */
    #why { padding: 100px 0; }

    .why-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; margin-top: 52px; }
    @media(max-width:900px){ .why-grid{grid-template-columns:1fr; gap:36px;} }

    .why-visual { background: var(--s2); border: 1px solid var(--border); border-radius: 20px; padding: 36px; display: flex; flex-direction: column; align-items: center; text-align: center; }
    .why-icon-big { width: 80px; height: 80px; background: linear-gradient(135deg, var(--emerald), var(--sky-dark)); border-radius: 20px; display: flex; align-items: center; justify-content: center; margin-bottom: 20px; box-shadow: 0 8px 28px rgba(16,185,129,0.2); }
    .why-icon-big svg { width: 40px; height: 40px; color: #fff; }
    .why-visual h4 { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 20px; color: var(--emerald); margin-bottom: 10px; }
