    .contact-info p { font-size: 14px; color: var(--text-2); line-height: 1.7; margin-bottom: 28px; font-weight: 300; }
    .contact-links { display: flex; flex-direction: column; gap: 10px; }
    .contact-link { display: flex; align-items: center; gap: 10px; padding: 12px 14px; border-radius: 11px; background: var(--s2); border: 1px solid var(--border); font-size: 13px; color: var(--text-2); text-decoration: none; transition: all .2s; }
