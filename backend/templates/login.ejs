<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Login</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">

  <style>
    *, *::before, *::after {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      background: #f5f5f3;
      font-family: 'DM Sans', Arial, sans-serif;
      padding: 1.5rem;
    }

    .card {
      width: 100%;
      max-width: 420px;
      background: #ffffff;
      border: 0.5px solid #e0e0de;
      border-radius: 20px;
      padding: 2.5rem 2.5rem 2rem;
      position: relative;
      overflow: hidden;
    }

    .blob {
      position: absolute;
      border-radius: 50%;
      background: #f5f5f3;
      pointer-events: none;
    }
    .blob-1 { width: 180px; height: 180px; top: -60px; right: -60px; opacity: 0.7; }
    .blob-2 { width: 120px; height: 120px; bottom: -40px; left: -40px; opacity: 0.5; }

    .inner { position: relative; z-index: 1; }

    .header { margin-bottom: 2rem; }

    .icon-wrap {
      width: 44px;
      height: 44px;
      border-radius: 12px;
      background: #f5f5f3;
      border: 0.5px solid #ddd;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 1.25rem;
    }
    .icon-wrap i { font-size: 20px; color: #222; }

    h1 {
      font-size: 22px;
      font-weight: 500;
      color: #111;
      margin-bottom: 6px;
    }

    .subtitle { font-size: 14px; color: #777; }

    .field { margin-bottom: 14px; }

    .field-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 6px;
    }

    label {
      font-size: 13px;
      font-weight: 500;
      color: #555;
    }

    .forgot-link {
      font-size: 12px;
      color: #aaa;
      text-decoration: none;
    }
    .forgot-link:hover { color: #555; }

    .input-wrap { position: relative; }

    .input-icon {
      position: absolute;
      left: 12px;
      top: 50%;
      transform: translateY(-50%);
      font-size: 16px;
      color: #bbb;
      pointer-events: none;
    }

    input {
      width: 100%;
      padding: 10px 12px 10px 38px;
      font-size: 14px;
      font-family: inherit;
      border: 0.5px solid #ddd;
      border-radius: 8px;
      background: #fafafa;
      color: #111;
      outline: none;
      transition: border-color 0.15s, box-shadow 0.15s, background 0.15s;
    }
    input:focus {
      border-color: #aaa;
      box-shadow: 0 0 0 3px rgba(0,0,0,0.06);
      background: #fff;
    }
    input::placeholder { color: #ccc; }
    input.has-toggle { padding-right: 40px; }

    .toggle-btn {
      position: absolute;
      right: 10px;
      top: 50%;
      transform: translateY(-50%);
      background: none;
      border: none;
      cursor: pointer;
      padding: 4px;
      color: #bbb;
      display: flex;
      align-items: center;
      font-size: 16px;
      transition: color 0.15s;
    }
    .toggle-btn:hover { color: #555; }

    .btn-primary {
      width: 100%;
      padding: 11px;
      font-size: 14px;
      font-weight: 500;
      font-family: inherit;
      background: #111;
      color: #fff;
      border: none;
      border-radius: 8px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      transition: opacity 0.15s;
      margin-bottom: 1rem;
      margin-top: 6px;
    }
    .btn-primary:hover { opacity: 0.87; }
    .btn-primary:active { opacity: 0.7; transform: scale(0.99); }

    .divider {
      display: flex;
      align-items: center;
      gap: 10px;
      margin: 1rem 0;
      font-size: 12px;
      color: #bbb;
    }
    .divider::before,
    .divider::after {
      content: '';
      flex: 1;
      height: 0.5px;
      background: #e5e5e3;
    }

    .btn-oauth {
      width: 100%;
      padding: 10px;
      font-size: 13px;
      font-weight: 500;
      font-family: inherit;
      background: transparent;
      color: #555;
      border: 0.5px solid #ddd;
      border-radius: 8px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      transition: background 0.15s;
    }
    .btn-oauth:hover { background: #f5f5f3; }

    .footer {
      margin-top: 1.75rem;
      padding-top: 1.5rem;
      border-top: 0.5px solid #eee;
      text-align: center;
    }
    .footer p { font-size: 13px; color: #777; }
    .footer a { color: #111; font-weight: 500; text-decoration: none; }
    .footer a:hover { text-decoration: underline; }

    .terms {
      text-align: center;
      font-size: 11px;
      color: #bbb;
      margin-top: 1rem;
      line-height: 1.6;
    }
    .terms a { color: #888; }
  </style>
</head>
<body>

<div class="card">
  <div class="blob blob-1"></div>
  <div class="blob blob-2"></div>

  <div class="inner">

    <div class="header">
      <div class="icon-wrap">
        <i class="ti ti-robot"></i>
      </div>
      <h1>Welcome back</h1>
      <p class="subtitle">Sign in to continue to your AI assistant.</p>
    </div>

    <form action="/login" method="POST">

      <div class="field">
        <label for="email">Email address</label>
        <div class="input-wrap">
          <i class="ti ti-mail input-icon"></i>
          <input type="email" id="email" name="email" placeholder="you@example.com" required>
        </div>
      </div>

      <div class="field">
        <div class="field-header">
          <label for="password">Password</label>
          <a href="/forgot-password" class="forgot-link">Forgot password?</a>
        </div>
        <div class="input-wrap">
          <i class="ti ti-lock input-icon"></i>
          <input type="password" id="password" name="password" placeholder="Enter your password" class="has-toggle" required>
          <button type="button" class="toggle-btn" id="toggle-pw" aria-label="Toggle password visibility">
            <i class="ti ti-eye" id="toggle-icon"></i>
          </button>
        </div>
      </div>

      <button type="submit" class="btn-primary">
        Sign in
        <i class="ti ti-arrow-right"></i>
      </button>

    </form>

    <div class="divider">or continue with</div>

    <button class="btn-oauth">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
        <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
        <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
        <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
        <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
      </svg>
      Continue with Google
    </button>

    <div class="footer">
      <p>Don't have an account? <a href="/signup">Sign up</a></p>
    </div>

    <p class="terms">
      By signing in you agree to our <a href="#">Terms</a> and <a href="#">Privacy Policy</a>
    </p>

  </div>
</div>

<script>
  const pwInput = document.getElementById('password');
  const toggleBtn = document.getElementById('toggle-pw');
  const toggleIcon = document.getElementById('toggle-icon');

  toggleBtn.addEventListener('click', () => {
    const isPassword = pwInput.type === 'password';
    pwInput.type = isPassword ? 'text' : 'password';
    toggleIcon.className = isPassword ? 'ti ti-eye-off' : 'ti ti-eye';
  });
</script>

</body>
</html>