document.getElementById('profileBtn').addEventListener('click',()=>{
  if(!currentData.length) return alert('Upload data first.');
  const headers=Object.keys(currentData[0]),n=currentData.length,cont=document.getElementById('profileContent');
  cont.innerHTML='';
  headers.forEach(col=>{
    const vals=currentData.map(r=>r[col]),empty=vals.filter(v=>v===''||v===null||v===undefined).length,uniq=new Set(vals).size,nums=vals.map(v=>parseFloat(v)).filter(v=>!isNaN(v)),isNum=nums.length>n*0.6,fillPct=Math.round(((n-empty)/n)*100);
    const card=document.createElement('div'); card.className='bg-gray-900/60 border border-gray-700 rounded-lg p-3';
    card.innerHTML=`<div class="flex justify-between items-center mb-2"><span class="text-xs font-semibold text-white truncate max-w-[60%]">${col}</span><span class="text-xs px-2 py-0.5 rounded-full ${isNum?'bg-blue-900/60 text-blue-300':'bg-purple-900/60 text-purple-300'}">${isNum?'🔢 numeric':'🔤 text'}</span></div><div class="flex justify-between text-xs text-gray-400 mb-1.5"><span>Fill rate</span><span>${fillPct}% <span class="text-gray-500">(${empty} empty)</span></span></div><div class="profile-bar-bg mb-2"><div class="profile-bar-fill ${fillPct>80?'bg-green-500':fillPct>50?'bg-yellow-500':'bg-red-500'}" style="width:${fillPct}%"></div></div><div class="text-xs text-gray-400"><span>Unique: <strong class="text-gray-200">${uniq}</strong></span>${isNum?`<span class="ml-3">Min: <strong class="text-gray-200">${formatNum(Math.min(...nums))}</strong></span><span class="ml-3">Max: <strong class="text-gray-200">${formatNum(Math.max(...nums))}</strong></span>`:''}</div>`;
    cont.appendChild(card);
  });
  document.getElementById('profileSection').classList.remove('hidden');
  document.getElementById('summarySection').classList.add('hidden');
  document.getElementById('chartSection').classList.add('hidden');
});
document.getElementById('closeProfileBtn').addEventListener('click',()=>document.getElementById('profileSection').classList.add('hidden'));

/* ═══════════════════════════════════
   TABLE COMPARISON
═══════════════════════════════════ */
document.getElementById('tableComparisonBtn').addEventListener('click',()=>{
  if(!currentData.length) return alert('Upload data first.');
  renderComparisonTable(currentData);
  document.getElementById('tableComparisonSection').classList.remove('hidden');
  ['chartSection','summarySection','profileSection'].forEach(id=>document.getElementById(id).classList.add('hidden'));
});
function renderComparisonTable(data) {
  const headers=Object.keys(data[0]),hr=document.getElementById('comparisonTableHeader'),tb=document.getElementById('comparisonTableBody');
  hr.innerHTML=''; tb.innerHTML='';
  const numCols=headers.filter(h=>data.every(r=>!isNaN(parseFloat(r[h]))&&r[h]!==''));
  const colRng={}; numCols.forEach(h=>{const vals=data.map(r=>parseFloat(r[h]));colRng[h]={min:Math.min(...vals),max:Math.max(...vals)};});
  headers.forEach(h=>{const th=document.createElement('th');th.className='px-3 py-2.5 text-left text-gray-300 font-semibold border border-gray-700 bg-gray-800 text-xs whitespace-nowrap cursor-pointer hover:bg-gray-700 select-none';th.innerHTML=`${h} <span class="text-gray-500 text-xs"></span>`;th.addEventListener('click',()=>{if(sortState.col===h)sortState.dir=sortState.dir==='asc'?'desc':'asc';else{sortState.col=h;sortState.dir='asc';}document.getElementById('sortDirBtn').textContent=`${sortState.dir==='asc'?'↑':'↓'} ${sortState.dir.toUpperCase()}`;renderComparisonTable(getSortedData());});hr.appendChild(th);});
  data.slice(0,1000).forEach(row=>{const tr=document.createElement('tr');tr.className='border-t border-gray-800 hover:bg-gray-700/30 transition';headers.forEach(h=>{const td=document.createElement('td'),raw=row[h]!==undefined?row[h]:'-';let cls='px-3 py-2 text-gray-400 border border-gray-800/50 text-xs';if(numCols.includes(h)){const v=parseFloat(raw),{min,max}=colRng[h],p=max!==min?(v-min)/(max-min):0.5;cls+=p>=0.67?' cf-high':p>=0.33?' cf-mid':' cf-low';}td.className=cls;td.textContent=String(raw).substring(0,100);td.title=String(raw);tr.appendChild(td);});tb.appendChild(tr);});
  document.getElementById('comparisonRowCount').textContent=`Showing ${Math.min(data.length,1000)} of ${data.length} rows`;
  document.getElementById('comparisonColCount').textContent=`${headers.length} columns`;
}
function getSortedData() { if(!sortState.col) return currentData; return [...currentData].sort((a,b)=>{const av=a[sortState.col],bv=b[sortState.col],an=parseFloat(av),bn=parseFloat(bv);if(!isNaN(an)&&!isNaN(bn)) return sortState.dir==='asc'?an-bn:bn-an;return sortState.dir==='asc'?String(av).localeCompare(String(bv)):String(bv).localeCompare(String(av));}); }
document.getElementById('sortDirBtn').addEventListener('click',()=>{if(!sortState.col)return;sortState.dir=sortState.dir==='asc'?'desc':'asc';document.getElementById('sortDirBtn').textContent=`${sortState.dir==='asc'?'↑':'↓'} ${sortState.dir.toUpperCase()}`;renderComparisonTable(getSortedData());});
document.getElementById('sortColumnSelect').addEventListener('change',e=>{sortState.col=e.target.value||null;renderComparisonTable(getSortedData());});
document.getElementById('comparisonTableSearch').addEventListener('keyup',e=>{const q=e.target.value.toLowerCase();let count=0;document.querySelectorAll('#comparisonTableBody tr').forEach(tr=>{const show=tr.innerText.toLowerCase().includes(q);tr.style.display=show?'':'none';if(show)count++;});document.getElementById('comparisonRowCount').textContent=`Showing ${count} of ${currentData.length} rows (filtered)`;});
document.getElementById('closeComparisonBtn').addEventListener('click',()=>document.getElementById('tableComparisonSection').classList.add('hidden'));

/* ═══════════════════════════════════
   EXPORTS
═══════════════════════════════════ */
function exportExcel() { if(!currentData.length) return alert('Upload data first.'); const ws=XLSX.utils.json_to_sheet(currentData),wb=XLSX.utils.book_new();XLSX.utils.book_append_sheet(wb,ws,'Data');XLSX.writeFile(wb,`export-${Date.now()}.xlsx`);botStatus.textContent='Exported as Excel'; }
document.getElementById('exportExcelBtn').addEventListener('click',exportExcel);
document.getElementById('exportExcelBtnMain').addEventListener('click',exportExcel);

document.getElementById('downloadDataBtn').addEventListener('click',()=>{
  if(!currentData.length) return alert('Upload data first.');
  const headers=Object.keys(currentData[0]);
  let csv=headers.join(',')+'\n';
  currentData.forEach(row=>{csv+=headers.map(h=>{const v=String(row[h]||'').replace(/"/g,'""');return v.includes(',')?`"${v}"`:v;}).join(',')+'\n';});
  const a=document.createElement('a');a.href='data:text/csv;charset=utf-8,'+encodeURIComponent(csv);a.download=`export-${Date.now()}.csv`;a.click();
  botStatus.textContent='CSV exported';
});

document.getElementById('exportPdfBtn').addEventListener('click',()=>{
  const msgs=Array.from(chatMessages.querySelectorAll('.flex'));
  if(!msgs.length) return alert('No chat to export.');
  let html=`<div style="font-family:Arial;color:#333;padding:20px"><h1 style="color:#0ea5e9">VizChat Export</h1><p style="color:#666">${new Date().toLocaleString()}</p><hr>`;
  msgs.forEach(m=>{const isUser=m.classList.contains('justify-end');html+=`<div style="margin:12px 0;padding:10px;background:${isUser?'#e0f2fe':'#f3f4f6'};border-left:3px solid ${isUser?'#0ea5e9':'#9ca3af'};border-radius:4px"><strong>${isUser?'You':'Bot'}:</strong><p style="margin:6px 0;white-space:pre-wrap">${m.innerText}</p></div>`;});
  html+='</div>';
  const el=document.createElement('div');el.innerHTML=html;
  html2pdf().set({margin:10,filename:`chat-${Date.now()}.pdf`,html2canvas:{scale:2},jsPDF:{orientation:'portrait',unit:'mm',format:'a4'}}).from(el).save();
});

/* ═══════════════════════════════════
   MISC
═══════════════════════════════════ */
document.getElementById('clearChatBtn').addEventListener('click',()=>{if(!confirm('Clear all chat messages?'))return;chatMessages.innerHTML='';addChatMessage('bot','🧹 Chat cleared. Ready for new questions!');document.querySelectorAll('#dataPreview tbody tr.cross-highlight').forEach(tr=>tr.classList.remove('cross-highlight'));});

document.getElementById('saveBotBtn').addEventListener('click',()=>{
  if(!currentData.length) return alert('Upload data first.');
  const name=prompt('Bot name:'); if(!name) return;
  const saved=JSON.parse(localStorage.getItem('savedBots')||'[]');
  saved.push({name,data:currentData,fileName:uploadedFile?.name,createdAt:new Date().toISOString(),type:'data-driven',alerts:alertRules,roles:rlsRoles});
  localStorage.setItem('savedBots',JSON.stringify(saved));
  alert('Bot saved!'); botStatus.textContent='Bot saved ✓';
});

function getMedian(arr) { if(!arr.length) return 0; const s=[...arr].sort((a,b)=>a-b),m=Math.floor(s.length/2); return s.length%2?s[m]:(s[m-1]+s[m])/2; }
function getStdDev(arr) { if(!arr.length) return 0; const mean=arr.reduce((a,b)=>a+b,0)/arr.length; return Math.sqrt(arr.reduce((a,b)=>a+Math.pow(b-mean,2),0)/arr.length); }
function formatNum(n) { if(isNaN(n)) return 'N/A'; if(Math.abs(n)>=1e6) return (n/1e6).toFixed(2)+'M'; if(Math.abs(n)>=1e3) return (n/1e3).toFixed(2)+'K'; return Number(n.toFixed(2)).toLocaleString(); }

</script>
