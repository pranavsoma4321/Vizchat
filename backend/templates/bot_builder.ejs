                  <thead class="sticky top-0 bg-gray-800"><tr id="comparisonTableHeader"></tr></thead>
                  <tbody id="comparisonTableBody" class="divide-y divide-gray-800"></tbody>
                </table>
              </div>
              <div class="bg-gray-800 px-4 py-2 border-t border-gray-700 text-xs text-gray-400 flex justify-between">
                <span id="comparisonRowCount">No data</span><span id="comparisonColCount"></span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ── Action Bar ── -->
    <div class="bg-gray-800 rounded-xl border border-gray-700 p-4">
      <div class="flex justify-between items-center flex-wrap gap-3">
        <div>
          <p class="text-gray-400 text-xs">Status</p>
          <p id="botStatus" class="text-white font-semibold text-sm">Ready</p>
        </div>
        <div class="flex gap-2 flex-wrap">
          <button id="clearChatBtn"      class="bg-red-700 hover:bg-red-600 text-white font-semibold px-4 py-2 rounded-lg transition text-xs" data-tip="Clear chat">🗑️ Clear Chat</button>
          <button id="downloadDataBtn"   class="bg-green-700 hover:bg-green-600 text-white font-semibold px-4 py-2 rounded-lg transition text-xs" data-tip="Export CSV">📥 CSV</button>
          <button id="exportExcelBtnMain" class="bg-emerald-700 hover:bg-emerald-600 text-white font-semibold px-4 py-2 rounded-lg transition text-xs" data-tip="Export Excel">📊 Excel</button>
          <button id="exportPdfBtn"      class="bg-orange-700 hover:bg-orange-600 text-white font-semibold px-4 py-2 rounded-lg transition text-xs" data-tip="Export PDF">📄 PDF</button>
          <button id="saveBotBtn"        class="bg-indigo-700 hover:bg-indigo-600 text-white font-semibold px-4 py-2 rounded-lg transition text-xs" data-tip="Save bot">💾 Save Bot</button>
        </div>
      </div>
    </div>
  </main>

<!-- ═══════════════════════════════════════════════════════════
     JAVASCRIPT
═══════════════════════════════════════════════════════════ -->
<script type="module">

/* ───────── State ───────── */
let rawData = [], currentData = [], uploadedFile = null, currentChart = null;
let slicerState = {}, sortState = { col: null, dir: 'asc' };
let alertRules = [], rlsRoles = [], botVersions = [];
let selectedTemplate = 'summary', activeRoleFilter = null;
let alertCheckInterval = null;

/* ───────── DOM ───────── */
const chatMessages = document.getElementById('chatMessages');
const chatForm = document.getElementById('chatForm');
const chatInput = document.getElementById('chatInput');
const botStatus = document.getElementById('botStatus');
const tableSearch = document.getElementById('tableSearch');

/* ───────── Template loader ───────── */
const urlParams = new URLSearchParams(window.location.search);
if (urlParams.get('template') === 'true') {
  const td = sessionStorage.getItem('templateData'), tn = sessionStorage.getItem('templateName');
  if (td) {
    rawData = JSON.parse(td); currentData = [...rawData];
    uploadedFile = { name: tn + '.csv' }; botStatus.textContent = `Loaded: ${tn}`;
    onDataReady(); sessionStorage.removeItem('templateData'); sessionStorage.removeItem('templateName');
  }
}

/* ═══════════════════════════════════
   FILE HANDLING
═══════════════════════════════════ */
document.addEventListener('DOMContentLoaded', () => {
  const dropZone = document.getElementById('dropZone');
  const fileInput = document.getElementById('fileInput');
  dropZone.addEventListener('click', () => fileInput.click());
  fileInput.addEventListener('change', function() { if (this.files[0]) handleFile(this.files[0]); });
  ['dragenter','dragover','dragleave','drop'].forEach(ev => {
    dropZone.addEventListener(ev, e => { e.preventDefault(); e.stopPropagation(); });
    document.body.addEventListener(ev, e => { e.preventDefault(); e.stopPropagation(); });
  });
  ['dragenter','dragover'].forEach(ev => dropZone.addEventListener(ev, () => dropZone.classList.add('border-sky-500','bg-sky-500/10')));
  ['dragleave','drop'].forEach(ev => dropZone.addEventListener(ev, () => dropZone.classList.remove('border-sky-500','bg-sky-500/10')));
  dropZone.addEventListener('drop', e => { const f = e.dataTransfer.files[0]; if (f) handleFile(f); });
});

function handleFile(file) {
  if (!file) return;
  uploadedFile = file;
  const reader = new FileReader();
  reader.onload = e => {
    try {
      let data = [];
      const content = e.target.result;
      if (file.name.endsWith('.csv')) data = parseCSV(content);
      else if (file.name.endsWith('.json')) { data = JSON.parse(content); if (!Array.isArray(data)) data = [data]; }
      else if (file.name.endsWith('.xlsx') || file.name.endsWith('.xls')) {
        const wb = XLSX.read(content, { type: 'binary' });
        const ws = wb.Sheets[wb.SheetNames[0]];
        data = XLSX.utils.sheet_to_json(ws, { defval: '' });
      } else { addChatMessage('bot', '❌ Unsupported format. Use CSV, JSON, or Excel.'); return; }
      if (data.length === 0) { addChatMessage('bot', '⚠️ No data rows found. Check your file.'); return; }
      rawData = data; currentData = [...rawData]; slicerState = {};
      onDataReady();
      chatMessages.innerHTML = '';
      addChatMessage('bot', `✅ Loaded **${data.length} rows × ${Object.keys(data[0]).length} columns** from *${file.name}*.\n\nTry the AI Insights tab, or ask me anything!`);
    } catch (err) { addChatMessage('bot', '❌ Parse error: ' + err.message); }
  };
  if (file.name.endsWith('.xlsx') || file.name.endsWith('.xls')) reader.readAsBinaryString(file);
  else reader.readAsText(file);
}

function parseCSV(content) {
  const lines = content.trim().split('\n').filter(l => l.trim());
  if (lines.length < 2) throw new Error('CSV needs a header row and at least one data row.');
  const headers = lines[0].split(',').map(h => h.trim().replace(/^"|"$/g, ''));
  return lines.slice(1).filter(l => l.trim()).map(line => {
    const vals = smartSplitCSV(line); const obj = {};
    headers.forEach((h, i) => { obj[h] = (vals[i] || '').trim(); }); return obj;
  });
}
function smartSplitCSV(line) {
  const result = []; let cur = '', inQ = false;
  for (let i = 0; i < line.length; i++) {
    const c = line[i];
    if (c === '"') { inQ = !inQ; continue; }
    if (c === ',' && !inQ) { result.push(cur); cur = ''; continue; }
    cur += c;
  }
  result.push(cur); return result;
}

/* ═══════════════════════════════════
   ON DATA READY
═══════════════════════════════════ */
function onDataReady() {
  displayDataPreview(currentData);
  buildKPICards();
  buildSlicers();
  buildQAChips();
  populateColumnSelector();
  populateAlertColumns();
  populateRLSColumns();
  populateInfluencerTarget();
  document.getElementById('visualizationSection').classList.remove('hidden');
  document.getElementById('kpiSection').classList.remove('hidden');
  document.getElementById('premiumSection').classList.remove('hidden');
  botStatus.textContent = `${currentData.length} rows loaded`;
  generateAIInsights();
  startAlertMonitor();
}

/* ═══════════════════════════════════
   DATA PREVIEW
═══════════════════════════════════ */
function displayDataPreview(data) {
  if (!data.length) return;
  const headers = Object.keys(data[0]);
  const numCols = headers.filter(h => data.every(r => !isNaN(parseFloat(r[h])) && r[h] !== ''));
  const colRanges = {};
  numCols.forEach(h => { const vals = data.map(r => parseFloat(r[h])); colRanges[h] = { min: Math.min(...vals), max: Math.max(...vals) }; });
  let html = '<div style="overflow-x:auto;"><table class="w-full text-xs border-collapse"><thead class="sticky top-0"><tr>';
  headers.forEach(h => { html += `<th class="px-3 py-2 text-left text-gray-300 font-semibold border border-gray-700 bg-gray-700 whitespace-nowrap">${h}</th>`; });
  html += '</tr></thead><tbody>';
  data.slice(0, 500).forEach((row, ri) => {
    html += `<tr class="border-t border-gray-700 hover:bg-gray-700/40 transition" data-ri="${ri}">`;
    headers.forEach(h => {
      const raw = row[h] !== undefined ? row[h] : '';
      let cls = 'px-3 py-2 text-gray-400 border border-gray-700/50';
      if (numCols.includes(h)) { const v = parseFloat(raw); const { min, max } = colRanges[h]; const pct = max !== min ? (v - min) / (max - min) : 0.5; cls += pct >= 0.67 ? ' cf-high' : pct >= 0.33 ? ' cf-mid' : ' cf-low'; }
      html += `<td class="${cls}" title="${String(raw)}">${String(raw).substring(0, 60)}</td>`;
    }); html += '</tr>';
  });
  html += '</tbody></table></div>';
  const pv = document.getElementById('dataPreview');
  pv.innerHTML = html; pv.style.overflow = 'auto';
  document.getElementById('rowCount').textContent = `Showing ${Math.min(data.length, 500)} of ${data.length} rows · 🟢 high  🟡 mid  🔴 low`;
  const size = (JSON.stringify(data).length / 1024).toFixed(1);
  document.getElementById('statRows').textContent = rawData.length;
  document.getElementById('statColumns').textContent = headers.length;
  document.getElementById('statSize').textContent = size + ' KB';
  document.getElementById('dataStats').classList.remove('hidden');
  document.getElementById('tableSearch').classList.remove('hidden');
}

tableSearch.addEventListener('keyup', e => {
  const q = e.target.value.toLowerCase();
  document.querySelectorAll('#dataPreview tbody tr').forEach(tr => { tr.style.display = tr.innerText.toLowerCase().includes(q) ? '' : 'none'; });
});

/* ═══════════════════════════════════
   KPI CARDS
═══════════════════════════════════ */
function buildKPICards() {
  const headers = Object.keys(currentData[0]);
  const numericCols = headers.filter(h => currentData.slice(0, 50).some(r => !isNaN(parseFloat(r[h])) && r[h] !== ''));
  const colors = ['blue','green','purple','orange','red','cyan'];
  const emojis = ['📦','💰','📈','⚡','🎯','🔢'];
  const container = document.getElementById('kpiCards');
  container.innerHTML = '';
  addKPICard(container, '📋 Total Rows', rawData.length.toLocaleString(), `Filtered: ${currentData.length}`, 'blue', currentData.length < rawData.length ? 'trend-down' : 'trend-flat');
  numericCols.slice(0, 5).forEach((col, i) => {
    const vals = currentData.map(r => parseFloat(r[col])).filter(v => !isNaN(v));
    if (!vals.length) return;
    const sum = vals.reduce((a, b) => a + b, 0);
    addKPICard(container, emojis[(i + 1) % emojis.length] + ' ' + col, formatNum(sum), `Avg: ${formatNum(sum / vals.length)}`, colors[(i + 1) % colors.length], 'trend-flat');
  });
}
function addKPICard(container, label, value, sub, color, trendClass) {
  const div = document.createElement('div');
  div.className = `kpi-card ${color}`;
  div.innerHTML = `<div class="text-xs text-gray-400 mb-1 truncate">${label}</div><div class="text-xl font-bold text-white">${value}</div><div class="text-xs mt-1 ${trendClass}">${sub}</div>`;
  container.appendChild(div);
}

/* ═══════════════════════════════════
   PREMIUM TABS
═══════════════════════════════════ */
document.querySelectorAll('.prem-tab').forEach(tab => {
  tab.addEventListener('click', () => {
    document.querySelectorAll('.prem-tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.tab-content').forEach(tc => tc.classList.add('hidden'));
    tab.classList.add('active');
    document.getElementById('tab-' + tab.dataset.tab).classList.remove('hidden');
  });
});

/* ═══════════════════════════════════
   1. AI SMART NARRATIVES
═══════════════════════════════════ */
function generateAIInsights() {
  if (!currentData.length) return;
  const headers = Object.keys(currentData[0]);
  const n = currentData.length;
  const numCols = headers.filter(h => currentData.slice(0,20).some(r => !isNaN(parseFloat(r[h])) && r[h] !== ''));
  const catCols = headers.filter(h => { const u = new Set(currentData.map(r=>r[h])); return u.size<=30 && u.size>1; });
  const insights = [];

  // Insight 1: Row/Col overview
  insights.push({ icon: '📊', text: `Dataset contains <span class="ins-badge">${n.toLocaleString()} records</span> across <span class="ins-badge">${headers.length} fields</span>. ${numCols.length} numeric and ${catCols.length} categorical columns detected.` });

  // Insight 2: Top numeric column
  if (numCols.length) {
    const col = numCols[0];
    const vals = currentData.map(r => parseFloat(r[col])).filter(v => !isNaN(v));
    const sum = vals.reduce((a,b)=>a+b,0);
    const avg = sum/vals.length;
    const max = Math.max(...vals);
    const maxRow = currentData.find(r => parseFloat(r[col]) === max);
    insights.push({ icon: '💰', text: `Total <span class="ins-badge">${col}</span> is <span class="ins-badge">${formatNum(sum)}</span>, averaging <span class="ins-badge">${formatNum(avg)}</span> per record. Highest single value is <span class="ins-badge">${formatNum(max)}</span>.` });
    if (maxRow) {
      const name = getProductName(maxRow);
      insights.push({ icon: '🏆', text: `Top performer: <span class="ins-badge">${name}</span> has the highest <span class="ins-badge">${col}</span> of <span class="ins-badge">${formatNum(max)}</span>.` });
    }
  }

  // Insight 3: Top category breakdown
  if (catCols.length && numCols.length) {
    const catCol = catCols[0], numCol = numCols[0];
    const groupSums = {};
    currentData.forEach(r => { const k = r[catCol]||'N/A'; const v = parseFloat(r[numCol])||0; groupSums[k] = (groupSums[k]||0) + v; });
    const sorted = Object.entries(groupSums).sort((a,b)=>b[1]-a[1]);
    if (sorted.length >= 2) {
      const total = sorted.reduce((a,b) => a+b[1],0);
      const top = sorted[0];
      const pct = total > 0 ? ((top[1]/total)*100).toFixed(1) : 0;
      insights.push({ icon: '🥇', text: `Top <span class="ins-badge">${catCol}</span>: <span class="ins-badge">${top[0]}</span> accounts for <span class="ins-badge">${pct}%</span> of total ${numCol} (${formatNum(top[1])}).` });
    }
  }

  // Insight 4: Completeness
  const allVals = headers.flatMap(h => currentData.map(r => r[h]));
  const empties = allVals.filter(v => v === '' || v === null || v === undefined).length;
  const completeness = (((allVals.length - empties) / allVals.length) * 100).toFixed(1);
  const quality = parseFloat(completeness) >= 95 ? '✅ Excellent' : parseFloat(completeness) >= 80 ? '⚠️ Good' : '❌ Needs cleaning';
  insights.push({ icon: '🔬', text: `Data completeness: <span class="ins-badge">${completeness}%</span> — ${quality}. ${empties > 0 ? `${empties} missing values found.` : 'No missing values detected.'}` });

  // Insight 5: Variance / spread for first numeric
  if (numCols.length) {
    const col = numCols[0];
    const vals = currentData.map(r=>parseFloat(r[col])).filter(v=>!isNaN(v));
    const std = getStdDev(vals);
    const avg = vals.reduce((a,b)=>a+b,0)/vals.length;
    const cv = avg > 0 ? ((std/avg)*100).toFixed(1) : 0;
    const spread = parseFloat(cv) < 30 ? 'Low variability — consistent dataset' : parseFloat(cv) < 70 ? 'Moderate variability' : 'High variability — diverse dataset';
    insights.push({ icon: '📉', text: `<span class="ins-badge">${col}</span> coefficient of variation: <span class="ins-badge">${cv}%</span>. ${spread}.` });
  }

  // Insight 6: Duplicate check
  const strs = currentData.map(r => JSON.stringify(r));
  const uniqCount = new Set(strs).size;
  const dups = n - uniqCount;
  insights.push({ icon: dups > 0 ? '⚠️' : '✅', text: dups > 0 ? `Found <span class="ins-badge">${dups} duplicate rows</span> in the dataset. Consider deduplication for accurate analysis.` : `No duplicate rows detected. Dataset is clean.` });

  const grid = document.getElementById('insightsGrid');
  grid.innerHTML = insights.map(ins => `
    <div class="insight-card">
      <span class="ins-icon">${ins.icon}</span>
      ${ins.text}
    </div>`).join('');

  // Anomaly detection
  detectAnomalies();
}

function detectAnomalies() {
  if (!currentData.length) return;
  const headers = Object.keys(currentData[0]);
  const numCols = headers.filter(h => currentData.slice(0,20).some(r => !isNaN(parseFloat(r[h])) && r[h] !== ''));
  const anomalies = [];

  numCols.slice(0,3).forEach(col => {
    const vals = currentData.map(r=>parseFloat(r[col])).filter(v=>!isNaN(v));
    if (vals.length < 5) return;
    const mean = vals.reduce((a,b)=>a+b,0)/vals.length;
    const std = getStdDev(vals);
    const threshold = mean + 3*std;
    const outliers = currentData.filter(r => { const v = parseFloat(r[col]); return !isNaN(v) && v > threshold; });
    if (outliers.length > 0) {
      anomalies.push({ col, count: outliers.length, threshold: formatNum(threshold), example: getProductName(outliers[0]) });
    }
  });

  if (anomalies.length > 0) {
    const aSection = document.getElementById('anomalySection');
    aSection.classList.remove('hidden');
    document.getElementById('anomalyList').innerHTML = anomalies.map(a => `
      <div class="flex items-start gap-3 bg-amber-900/20 border border-amber-500/25 rounded-lg px-4 py-3">
        <span class="text-amber-400 text-lg mt-0.5">⚠️</span>
        <div>
          <p class="text-sm text-amber-300 font-semibold">${a.count} outlier${a.count>1?'s':''} in <span class="ins-badge">${a.col}</span></p>
          <p class="text-xs text-gray-400 mt-1">Values exceed 3σ threshold of ${a.threshold}. Example: <em>${a.example}</em></p>
        </div>
      </div>`).join('');
  }
}

document.getElementById('refreshInsightsBtn').addEventListener('click', generateAIInsights);

/* ═══════════════════════════════════
   2. ALERT BUILDER
═══════════════════════════════════ */
function populateAlertColumns() {
  const headers = Object.keys(currentData[0] || {});
  const numCols = headers.filter(h => currentData.slice(0,10).some(r => !isNaN(parseFloat(r[h])) && r[h] !== ''));
  const sel = document.getElementById('alertColumn');
  sel.innerHTML = '<option value="">Select column</option>';
  numCols.forEach(h => { const o = document.createElement('option'); o.value=h; o.textContent=h; sel.appendChild(o); });
}

document.getElementById('addAlertBtn').addEventListener('click', () => {
  document.getElementById('alertForm').classList.toggle('hidden');
});
document.getElementById('cancelAlertBtn').addEventListener('click', () => {
  document.getElementById('alertForm').classList.add('hidden');
});

document.getElementById('saveAlertBtn').addEventListener('click', () => {
  const col = document.getElementById('alertColumn').value;
  const op = document.getElementById('alertOperator').value;
  const threshold = parseFloat(document.getElementById('alertThreshold').value);
  const name = document.getElementById('alertName').value || `Alert on ${col}`;
  if (!col || isNaN(threshold)) { alert('Fill in column and threshold.'); return; }
  alertRules.push({ id: Date.now(), name, col, op, threshold, triggered: false, active: true });
  document.getElementById('alertForm').classList.add('hidden');
  document.getElementById('alertColumn').value = '';
  document.getElementById('alertThreshold').value = '';
  document.getElementById('alertName').value = '';
  renderAlertsList();
  checkAlerts();
});

function renderAlertsList() {
  const container = document.getElementById('alertsList');
  if (!alertRules.length) { container.innerHTML = '<p class="text-gray-500 text-sm">No alerts configured yet.</p>'; return; }
  container.innerHTML = alertRules.map(rule => {
    const opLabels = { gt:'>',lt:'<',gte:'≥',lte:'≤',eq:'=' };
    return `
    <div class="alert-rule ${rule.triggered ? 'triggered' : 'ok'}" id="rule-${rule.id}">
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-3">
          <span class="text-lg">${rule.triggered ? '🔴' : '🟢'}</span>
          <div>
            <p class="text-sm font-semibold text-white">${rule.name}</p>
            <p class="text-xs text-gray-400">${rule.col} ${opLabels[rule.op]} ${formatNum(rule.threshold)}</p>
          </div>
        </div>
        <div class="flex items-center gap-2">
          <span class="alert-status text-xs font-semibold">${rule.triggered ? '⚠️ TRIGGERED' : '✓ OK'}</span>
          <button onclick="deleteAlert(${rule.id})" class="text-xs text-red-400 hover:text-red-300 px-2 py-1 rounded hover:bg-red-900/20 transition">✕</button>
        </div>
      </div>
      ${rule.triggered ? `<p class="text-xs text-red-300 mt-2 ml-8">Alert condition met — ${rule.triggeredRows || 0} row(s) match.</p>` : ''}
    </div>`;
  }).join('');
}

window.deleteAlert = (id) => {
  alertRules = alertRules.filter(r => r.id !== id);
  renderAlertsList();
  updateAlertCount();
};

function checkAlerts() {
  if (!currentData.length || !alertRules.length) return;
  let triggered = 0;
  alertRules.forEach(rule => {
    const ops = { gt:(a,b)=>a>b, lt:(a,b)=>a<b, gte:(a,b)=>a>=b, lte:(a,b)=>a<=b, eq:(a,b)=>a===b };
    const matches = currentData.filter(r => { const v = parseFloat(r[rule.col]); return !isNaN(v) && ops[rule.op](v, rule.threshold); });
    const wasTriggered = rule.triggered;
    rule.triggered = matches.length > 0;
    rule.triggeredRows = matches.length;
    if (rule.triggered && !wasTriggered) {
      showAlertToast(rule);
      triggered++;
    }
  });
  renderAlertsList();
  updateAlertCount();
}

function showAlertToast(rule) {
  const opLabels = { gt:'>',lt:'<',gte:'≥',lte:'≤',eq:'=' };
  const toast = document.createElement('div');
  toast.className = 'alert-badge';
  toast.innerHTML = `<strong>🔔 ${rule.name}</strong><br><span style="font-size:0.75rem;opacity:.85">${rule.col} ${opLabels[rule.op]} ${formatNum(rule.threshold)}: ${rule.triggeredRows} rows matched</span><br><button onclick="this.parentElement.remove()" style="margin-top:6px;font-size:0.7rem;background:rgba(255,255,255,.2);border:none;color:#fff;padding:2px 8px;border-radius:4px;cursor:pointer">Dismiss</button>`;
  document.getElementById('alertToastContainer').appendChild(toast);
  setTimeout(() => { if (toast.parentElement) toast.remove(); }, 8000);
}

function updateAlertCount() {
  const count = alertRules.filter(r => r.triggered).length;
  const badge = document.getElementById('alertCountBadge');
  if (count > 0) { badge.textContent = count; badge.classList.remove('hidden'); }
  else { badge.classList.add('hidden'); }
}

function startAlertMonitor() {
  if (alertCheckInterval) clearInterval(alertCheckInterval);
  alertCheckInterval = setInterval(checkAlerts, 30000);
  checkAlerts();
}

/* ═══════════════════════════════════
   3. KEY INFLUENCERS
═══════════════════════════════════ */
function populateInfluencerTarget() {
  const headers = Object.keys(currentData[0] || {});
  const numCols = headers.filter(h => currentData.slice(0,10).some(r => !isNaN(parseFloat(r[h])) && r[h] !== ''));
  const sel = document.getElementById('influencerTarget');
  sel.innerHTML = '<option value="">Select target column</option>';
  numCols.forEach(h => { const o = document.createElement('option'); o.value=h; o.textContent=h; sel.appendChild(o); });
}

document.getElementById('runInfluencersBtn').addEventListener('click', runKeyInfluencers);

function runKeyInfluencers() {
  const target = document.getElementById('influencerTarget').value;
  if (!target || !currentData.length) { alert('Select a target column first.'); return; }
  const headers = Object.keys(currentData[0]).filter(h => h !== target);
  const targetVals = currentData.map(r => parseFloat(r[target])).filter(v => !isNaN(v));
  if (targetVals.length < 3) { alert('Not enough numeric data in target column.'); return; }

  const targetMean = targetVals.reduce((a,b)=>a+b,0)/targetVals.length;

  // Calculate correlation for numeric cols and ANOVA for categorical
  const results = [];
  headers.forEach(col => {
    const vals = currentData.map(r => parseFloat(r[col])).filter(v => !isNaN(v));
    const isNum = vals.length > currentData.length * 0.5;
    if (isNum) {
      // Pearson correlation
      const n = Math.min(vals.length, targetVals.length, currentData.length);
      const xArr = currentData.slice(0,n).map(r => parseFloat(r[col])).filter(v=>!isNaN(v));
      const yArr = currentData.slice(0,n).map(r => parseFloat(r[target])).filter(v=>!isNaN(v));
      const len = Math.min(xArr.length, yArr.length);
      if (len < 3) return;
      const xMean = xArr.slice(0,len).reduce((a,b)=>a+b,0)/len;
      const yMean = yArr.slice(0,len).reduce((a,b)=>a+b,0)/len;
      let num=0, dx=0, dy=0;
      for (let i=0;i<len;i++) { num += (xArr[i]-xMean)*(yArr[i]-yMean); dx += (xArr[i]-xMean)**2; dy += (yArr[i]-yMean)**2; }
      const corr = (dx*dy > 0) ? num/Math.sqrt(dx*dy) : 0;
      results.push({ col, type: 'numeric', score: Math.abs(corr), corr, isPositive: corr >= 0 });
    } else {
      // Group mean difference for categorical
      const groups = {};
      currentData.forEach(r => { const k = r[col]||'N/A'; const v = parseFloat(r[target]); if (!isNaN(v)) { if(!groups[k]) groups[k]=[]; groups[k].push(v); } });
      const groupMeans = Object.entries(groups).map(([k,arr]) => ({ k, mean: arr.reduce((a,b)=>a+b,0)/arr.length, n: arr.length }));
      if (groupMeans.length < 2) return;
      const maxDiff = Math.max(...groupMeans.map(g => Math.abs(g.mean - targetMean)));
      const normScore = Math.min(maxDiff / (targetMean + 0.001), 1);
      const topGroup = groupMeans.sort((a,b)=>b.mean-a.mean)[0];
      results.push({ col, type: 'categorical', score: normScore, topGroup, isPositive: topGroup.mean >= targetMean });
    }
  });

  results.sort((a,b) => b.score - a.score);
  const top = results.slice(0, 8);
  const container = document.getElementById('influencersResult');

  if (!top.length) { container.innerHTML = '<p class="text-gray-500 text-sm">No significant influencers found.</p>'; return; }

  const increasers = top.filter(r => r.isPositive);
  const decreasers = top.filter(r => !r.isPositive);

  function renderList(items, label, color) {
    if (!items.length) return '';
    return `<div>
      <h5 class="text-sm font-bold mb-3" style="color:${color}">${label}</h5>
      ${items.map(r => `
        <div class="influencer-row">
          <span class="influencer-label" title="${r.col}">${r.col}</span>
          <div class="influencer-bar-bg">
            <div class="influencer-bar-fill" style="width:${Math.round(r.score*100)}%;background:${color}80;border:1px solid ${color}60"></div>
          </div>
          <span class="influencer-val">${r.type==='numeric' ? (r.corr>=0?'+':'')+r.corr.toFixed(2) : Math.round(r.score*100)+'%'}</span>
          <span class="influencer-dir">${r.isPositive ? '⬆️' : '⬇️'}</span>
        </div>`).join('')}
    </div>`;
  }

  container.innerHTML = renderList(increasers, '⬆️ Increases ' + target, '#10b981') + renderList(decreasers, '⬇️ Decreases ' + target, '#ef4444');
  setTimeout(() => {
    container.querySelectorAll('.influencer-bar-fill').forEach(el => {
      const w = el.style.width; el.style.width = '0%';
      setTimeout(() => { el.style.width = w; }, 50);
    });
  }, 50);
}

