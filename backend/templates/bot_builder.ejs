/* ═══════════════════════════════════
   NL → CHART (Enhanced Chat)
═══════════════════════════════════ */
function detectChartIntent(query) {
  const lq = query.toLowerCase();
  if (/bar chart|bar graph|show bar/.test(lq)) return 'bar';
  if (/pie chart|pie graph|show pie/.test(lq)) return 'pie';
  if (/line chart|line graph|trend/.test(lq)) return 'line';
  if (/area chart|area graph/.test(lq)) return 'area';
  if (/scatter|correlation between/.test(lq)) return 'scatter';
  return null;
}

function searchData(query) {
  if (!currentData.length) return [];
  const lq = query.toLowerCase().trim(), words = lq.split(/\s+/);
  return currentData.map((row,idx) => {
    let score = 0; const rowStr = JSON.stringify(row).toLowerCase();
    words.forEach(w => { if (w.length>2&&rowStr.includes(w)) score+=10; });
    Object.values(row).forEach(v => { if (String(v).toLowerCase().includes(lq)) score+=15; });
    return { ...row, _score: score, _idx: idx };
  }).filter(r=>r._score>0).sort((a,b)=>b._score-a._score);
}

function getFieldValue(row, names) {
  for (const n of names) { const k=Object.keys(row).find(k=>k.toLowerCase()===n.toLowerCase()); if(k&&row[k]!==undefined&&row[k]!=='') return row[k]; }
  return '';
}
function getProductName(row) {
  const n=getFieldValue(row,['name','product','item','title','description','item_name','product_name']);
  if (n) return n;
  for (const k of Object.keys(row)) { const v=String(row[k]); if (isNaN(v)&&v.trim()) return v; }
  return 'Record';
}

function generateResponse(query, results) {
  const lq = query.toLowerCase();
  const headers = currentData.length ? Object.keys(currentData[0]) : [];

  if (/how many|count|number of|total rows/.test(lq))
    return `📊 **${currentData.length}** rows in current view (${rawData.length} total).`;
  if (/columns|fields|attributes|schema|headers/.test(lq))
    return `📋 **${headers.length} columns:**\n${headers.map((h,i)=>`${i+1}. ${h}`).join('\n')}`;
  if (/summary|overview|describe/.test(lq)) {
    const numCols = headers.filter(h=>currentData.slice(0,10).some(r=>!isNaN(parseFloat(r[h]))&&r[h]!==''));
    return `📈 **Dataset Overview**\n• Rows: ${currentData.length}\n• Columns: ${headers.length}\n• Numeric: ${numCols.join(', ')||'none'}\n• Text: ${headers.filter(h=>!numCols.includes(h)).join(', ')||'none'}`;
  }
  if (/total|sum/.test(lq)) {
    const colMatch = headers.find(h=>lq.includes(h.toLowerCase()));
    if (colMatch) { const vals=currentData.map(r=>parseFloat(r[colMatch])).filter(v=>!isNaN(v)); return `💰 Total **${colMatch}**: ${formatNum(vals.reduce((a,b)=>a+b,0))} (${vals.length} records)`; }
  }
  if (/average|avg|mean/.test(lq)) {
    const colMatch = headers.find(h=>lq.includes(h.toLowerCase()));
    if (colMatch) { const vals=currentData.map(r=>parseFloat(r[colMatch])).filter(v=>!isNaN(v)); return `📊 Average **${colMatch}**: ${formatNum(vals.reduce((a,b)=>a+b,0)/vals.length)}`; }
  }
  if (/max|highest|largest/.test(lq)) {
    const colMatch = headers.find(h=>lq.includes(h.toLowerCase()));
    if (colMatch) { const vals=currentData.map(r=>parseFloat(r[colMatch])).filter(v=>!isNaN(v)); const maxV=Math.max(...vals); return `📈 Max **${colMatch}**: ${formatNum(maxV)}\nRecord: ${getProductName(currentData.find(r=>parseFloat(r[colMatch])===maxV))}`; }
  }
  if (/min|lowest|smallest/.test(lq)) {
    const colMatch = headers.find(h=>lq.includes(h.toLowerCase()));
    if (colMatch) { const vals=currentData.map(r=>parseFloat(r[colMatch])).filter(v=>!isNaN(v)); const minV=Math.min(...vals); return `📉 Min **${colMatch}**: ${formatNum(minV)}\nRecord: ${getProductName(currentData.find(r=>parseFloat(r[colMatch])===minV))}`; }
  }
  if (/count by|group by|breakdown/.test(lq)) {
    const colMatch = headers.find(h=>lq.includes(h.toLowerCase()));
    if (colMatch) { const freq={}; currentData.forEach(r=>{const v=r[colMatch]||'N/A';freq[v]=(freq[v]||0)+1;}); return `📊 **${colMatch}** breakdown:\n`+Object.entries(freq).sort((a,b)=>b[1]-a[1]).slice(0,10).map(([k,v])=>`• ${k}: ${v}`).join('\n'); }
  }
  const topMatch = lq.match(/top\s*(\d+)/);
  if (topMatch) {
    const n=parseInt(topMatch[1]), numCol=headers.find(h=>currentData.slice(0,20).some(r=>!isNaN(parseFloat(r[h]))&&r[h]!==''));
    if (numCol) { const sorted=[...currentData].sort((a,b)=>parseFloat(b[numCol]||0)-parseFloat(a[numCol]||0)).slice(0,n); return `🏆 Top ${n} by **${numCol}**:\n`+sorted.map((r,i)=>`${i+1}. ${getProductName(r)} — ${formatNum(parseFloat(r[numCol]))}`).join('\n'); }
  }
  if (!results.length) return `❌ No results found for "${query}". Try the Q&A chips above.`;
  return `🔍 Found **${results.length}** result(s) for "${query}":\n`+results.slice(0,8).map((r,i)=>{
    const name=getProductName(r), price=getFieldValue(r,['price','cost','rate','amount']), qty=getFieldValue(r,['quantity','qty','stock']);
    let line=`${i+1}. ${name}`; if(price) line+=` — ₹${price}`; if(qty) line+=` (qty: ${qty})`; return line;
  }).join('\n');
}

/* ═══════════════════════════════════
   CHAT — NL→CHART AUTO-TRIGGER
═══════════════════════════════════ */
function addChatMessage(sender, message, chartSuggestion = null) {
  const ph = chatMessages.querySelector('.text-center'); if(ph) ph.remove();
  const div = document.createElement('div');
  div.className = `flex ${sender==='user'?'justify-end':'justify-start'}`;
  const bubble = document.createElement('div');
  bubble.className = sender==='user'
    ? 'bg-sky-600 text-white rounded-xl rounded-tr-none px-4 py-2.5 max-w-xs text-sm break-words'
    : 'bg-gray-700 text-gray-100 rounded-xl rounded-tl-none px-4 py-2.5 max-w-sm text-sm break-words';
  bubble.innerHTML = `<p class="whitespace-pre-wrap leading-relaxed">${message.replace(/\*\*(.+?)\*\*/g,'<strong>$1</strong>').replace(/\*(.+?)\*/g,'<em>$1</em>')}</p>`;
  if (chartSuggestion) {
    const sug = document.createElement('div');
    sug.className = 'nl-chart-suggestion';
    sug.innerHTML = `📊 Click to generate: <strong>${chartSuggestion.label}</strong>`;
    sug.addEventListener('click', chartSuggestion.action);
    bubble.appendChild(sug);
  }
  div.appendChild(bubble);
  chatMessages.appendChild(div);
  chatMessages.scrollTop = chatMessages.scrollHeight;
}

chatForm.addEventListener('submit', e => {
  e.preventDefault();
  const query = chatInput.value.trim(); if (!query) return;
  addChatMessage('user', query); chatInput.value = '';
  const typing = document.createElement('div');
  typing.className = 'flex justify-start';
  typing.innerHTML = '<div class="bg-gray-700 text-gray-400 rounded-xl px-4 py-2.5 text-sm">⏳ Thinking…</div>';
  chatMessages.appendChild(typing); chatMessages.scrollTop = chatMessages.scrollHeight;

  setTimeout(() => {
    typing.remove();
    const chartType = detectChartIntent(query);
    if (chartType && currentData.length) {
      const headers = Object.keys(currentData[0]);
      const numCol = headers.find(h=>currentData.slice(0,20).some(r=>!isNaN(parseFloat(r[h]))&&r[h]!==''));
      const catCol = headers.find(h=>{const u=new Set(currentData.map(r=>r[h]));return u.size<=20;});
      const col = headers.find(h=>query.toLowerCase().includes(h.toLowerCase())) || numCol || catCol;
      if (col) {
        document.getElementById('columnSelector').value = col;
        const actions = { bar: ()=>document.getElementById('barChartBtn').click(), pie: ()=>document.getElementById('pieChartBtn').click(), line: ()=>document.getElementById('lineChartBtn').click(), area: ()=>document.getElementById('areaChartBtn').click() };
        if (actions[chartType]) {
          actions[chartType]();
          addChatMessage('bot', `📊 Generated **${chartType} chart** for **${col}**! Check the visualization panel below.`);
          document.getElementById('visualizationSection').scrollIntoView({behavior:'smooth', block:'start'});
          return;
        }
      }
    }
    const results = searchData(query);
    const response = generateResponse(query, results);
    let chartSuggestion = null;
    if (results.length > 3 && results.length < currentData.length) {
      const headers = Object.keys(currentData[0]);
      const numCol = headers.find(h=>currentData.slice(0,20).some(r=>!isNaN(parseFloat(r[h]))&&r[h]!==''));
      if (numCol) {
        chartSuggestion = { label: `Bar chart for matching records by ${numCol}`, action: () => { document.getElementById('columnSelector').value = numCol; document.getElementById('barChartBtn').click(); }};
      }
    }
    addChatMessage('bot', response, chartSuggestion);
    if (results.length && results.length < currentData.length) {
      const indices = new Set(results.map(r=>r._idx));
      document.querySelectorAll('#dataPreview tbody tr').forEach(tr => { tr.classList.toggle('cross-highlight', indices.has(parseInt(tr.dataset.ri))); });
    }
  }, 600);
});

/* ═══════════════════════════════════
   CHARTS
═══════════════════════════════════ */
function getColData(col) { const freq={}; currentData.forEach(r=>{const v=r[col]!==undefined&&r[col]!==''?r[col]:'N/A';freq[v]=(freq[v]||0)+1;}); return freq; }
function chartColors(n) { const base=['#3b82f6','#ef4444','#10b981','#f59e0b','#8b5cf6','#ec4899','#06b6d4','#84cc16','#f97316','#6366f1']; const bg=[],bd=[]; for(let i=0;i<n;i++){bd.push(base[i%base.length]);bg.push(base[i%base.length]+'cc');} return {bg,bd}; }
const commonOpts = { responsive:true, maintainAspectRatio:false, plugins:{legend:{labels:{color:'#d1d5db',font:{size:11}}}} };
function mkChart(type,chartData,title,opts={}) {
  const ctx=document.getElementById('dataChart').getContext('2d');
  if(currentChart) currentChart.destroy();
  currentChart=new Chart(ctx,{type,data:chartData,options:{...commonOpts,...opts}});
  document.getElementById('chartTitle').textContent=title;
  document.getElementById('chartSection').classList.remove('hidden');
  ['summarySection','profileSection'].forEach(id=>document.getElementById(id).classList.add('hidden'));
}

document.getElementById('barChartBtn').addEventListener('click',()=>{
  const col=document.getElementById('columnSelector').value; if(!col) return alert('Select a column first.');
  const freq=getColData(col),labels=Object.keys(freq).slice(0,20),vals=labels.map(k=>freq[k]),{bg,bd}=chartColors(labels.length);
  mkChart('bar',{labels,datasets:[{label:col,data:vals,backgroundColor:bg,borderColor:bd,borderWidth:1}]},`Bar Chart — ${col}`,{onClick:(_,els)=>{if(!els.length)return;drillFilter(col,labels[els[0].index]);},scales:{x:{ticks:{color:'#9ca3af'},grid:{color:'#1f2937'}},y:{ticks:{color:'#9ca3af'},grid:{color:'#1f2937'},beginAtZero:true}}});
});
document.getElementById('pieChartBtn').addEventListener('click',()=>{
  const col=document.getElementById('columnSelector').value; if(!col) return alert('Select a column first.');
  const freq=getColData(col),labels=Object.keys(freq).slice(0,15),vals=labels.map(k=>freq[k]),{bg,bd}=chartColors(labels.length);
  mkChart('pie',{labels,datasets:[{data:vals,backgroundColor:bg,borderColor:bd,borderWidth:1}]},`Pie Chart — ${col}`,{onClick:(_,els)=>{if(!els.length)return;drillFilter(col,labels[els[0].index]);},plugins:{...commonOpts.plugins,tooltip:{callbacks:{label:ctx=>{const t=ctx.dataset.data.reduce((a,b)=>a+b,0);return `${ctx.label}: ${ctx.parsed} (${((ctx.parsed/t)*100).toFixed(1)}%)`; }}}}});
});
document.getElementById('lineChartBtn').addEventListener('click',()=>{
  const col=document.getElementById('columnSelector').value; if(!col) return alert('Select a column first.');
  const vals=currentData.map(r=>parseFloat(r[col])).filter(v=>!isNaN(v)),labels=vals.map((_,i)=>i+1);
  mkChart('line',{labels,datasets:[{label:col,data:vals,borderColor:'#3b82f6',backgroundColor:'rgba(59,130,246,0.1)',pointRadius:vals.length>200?0:2,fill:false,tension:0.3}]},`Line Chart — ${col}`,{scales:{x:{ticks:{color:'#9ca3af'},grid:{color:'#1f2937'}},y:{ticks:{color:'#9ca3af'},grid:{color:'#1f2937'}}}});
});
document.getElementById('areaChartBtn').addEventListener('click',()=>{
  const col=document.getElementById('columnSelector').value; if(!col) return alert('Select a column first.');
  const vals=currentData.map(r=>parseFloat(r[col])).filter(v=>!isNaN(v)),labels=vals.map((_,i)=>i+1);
  mkChart('line',{labels,datasets:[{label:col,data:vals,borderColor:'#8b5cf6',backgroundColor:'rgba(139,92,246,0.25)',pointRadius:vals.length>200?0:2,fill:true,tension:0.4}]},`Area Chart — ${col}`,{scales:{x:{ticks:{color:'#9ca3af'},grid:{color:'#1f2937'}},y:{ticks:{color:'#9ca3af'},grid:{color:'#1f2937'}}}});
});
document.getElementById('scatterBtn').addEventListener('click',()=>{
  const col1=document.getElementById('columnSelector').value,col2=document.getElementById('chart2ndColumn').value;
  if(!col1||!col2) return alert('Select both columns for scatter plot.');
  const pts=currentData.map(r=>({x:parseFloat(r[col1]),y:parseFloat(r[col2])})).filter(p=>!isNaN(p.x)&&!isNaN(p.y));
  mkChart('scatter',{datasets:[{label:`${col1} vs ${col2}`,data:pts,backgroundColor:'rgba(236,72,153,0.5)',borderColor:'#ec4899',pointRadius:4}]},`Scatter — ${col1} × ${col2}`,{scales:{x:{title:{display:true,text:col1,color:'#9ca3af'},ticks:{color:'#9ca3af'},grid:{color:'#1f2937'}},y:{title:{display:true,text:col2,color:'#9ca3af'},ticks:{color:'#9ca3af'},grid:{color:'#1f2937'}}}});
});

function drillFilter(col,val) {
  if(!slicerState[col]) slicerState[col]=new Set();
  slicerState[col].add(String(val));
  document.querySelector(`.slicer-chip[data-col="${col}"][data-val="${val}"]`)?.classList.add('active');
  applySlicers();
  addChatMessage('bot',`🔍 Drilled into **${col} = ${val}** — ${currentData.length} rows shown.`);
}

