  }

  let profileHtml = '';
  if (inclProfile) {
    const profRows = headers.map(col => {
      const vals = currentData.map(r=>r[col]);
      const empty = vals.filter(v=>v===''||v===null).length;
      const uniq = new Set(vals).size;
