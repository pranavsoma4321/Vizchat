/* ═══════════════════════════════════
   SLICERS
═══════════════════════════════════ */
function buildSlicers() {
  const headers = Object.keys(currentData[0]);
  const catCols = headers.filter(h => { const u = new Set(currentData.map(r=>r[h])); return u.size<=30 && u.size>1; }).slice(0,5);
  const container = document.getElementById('slicerControls');
  container.innerHTML = ''; slicerState = {};
  catCols.forEach(col => {
    slicerState[col] = new Set();
    const uniq = [...new Set(currentData.map(r=>r[col]))].filter(v=>v!=='').sort();
    const wrap = document.createElement('div');
    wrap.innerHTML = `<div class="text-xs text-gray-400 font-semibold mb-1.5">${col}</div>`;
    const chips = document.createElement('div'); chips.className = 'flex flex-wrap gap-1';
    uniq.forEach(val => {
      const chip = document.createElement('span'); chip.className = 'slicer-chip';
      chip.textContent = val; chip.dataset.col = col; chip.dataset.val = val;
      chip.addEventListener('click', () => {
        chip.classList.toggle('active');
        if (slicerState[col].has(val)) slicerState[col].delete(val); else slicerState[col].add(val);
        applySlicers();
      });
      chips.appendChild(chip);
    });
    wrap.appendChild(chips); container.appendChild(wrap);
  });
  if (!catCols.length) container.innerHTML = '<p class="text-xs text-gray-500">No categorical columns detected.</p>';
}

function applySlicers() {
  currentData = rawData.filter(row => Object.entries(slicerState).every(([col,sel]) => sel.size===0 || sel.has(row[col])));
  if (activeRoleFilter) currentData = currentData.filter(row => activeRoleFilter.vals.includes(String(row[activeRoleFilter.col])));
  displayDataPreview(currentData); buildKPICards(); updateFilterBadge();
  botStatus.textContent = `Filtered: ${currentData.length} / ${rawData.length} rows`;
  checkAlerts();
}

function updateFilterBadge() {
  const badge = document.getElementById('activeFilterBadge'), chipsDiv = document.getElementById('filterChips');
  const active = Object.entries(slicerState).filter(([,s])=>s.size>0);
  if (!active.length) { badge.classList.add('hidden'); return; }
  badge.classList.remove('hidden'); chipsDiv.innerHTML = '';
  active.forEach(([col,sel]) => {
    sel.forEach(val => {
      const chip = document.createElement('span'); chip.className = 'slicer-chip active';
      chip.innerHTML = `${col}: ${val} <span class="remove" data-col="${col}" data-val="${val}">✕</span>`;
      chip.querySelector('.remove').addEventListener('click', e => {
        e.stopPropagation(); slicerState[col].delete(val);
        document.querySelector(`.slicer-chip[data-col="${col}"][data-val="${val}"]`)?.classList.remove('active');
        applySlicers();
      });
      chipsDiv.appendChild(chip);
    });
  });
}

document.getElementById('clearAllFilters').addEventListener('click', () => {
  Object.keys(slicerState).forEach(k=>slicerState[k].clear());
  document.querySelectorAll('.slicer-chip').forEach(c=>c.classList.remove('active'));
  applySlicers();
});
document.getElementById('resetSlicers').addEventListener('click', () => document.getElementById('clearAllFilters').click());

