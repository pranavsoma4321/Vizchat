<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Data-Driven Chatbot Builder - VizChat</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

  <style>
    body { overflow-x: hidden; font-family: 'Inter', sans-serif; }

    /* ── KPI Cards ── */
    .kpi-card {
      background: linear-gradient(135deg, rgba(30,41,59,0.9), rgba(15,23,42,0.9));
      border: 1px solid rgba(148,163,184,0.15);
      border-radius: 12px; padding: 16px;
      transition: transform .2s, box-shadow .2s;
      position: relative; overflow: hidden;
    }
    .kpi-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; border-radius: 12px 12px 0 0; }
    .kpi-card.blue::before   { background: linear-gradient(90deg,#3b82f6,#60a5fa); }
    .kpi-card.green::before  { background: linear-gradient(90deg,#10b981,#34d399); }
    .kpi-card.purple::before { background: linear-gradient(90deg,#8b5cf6,#a78bfa); }
    .kpi-card.orange::before { background: linear-gradient(90deg,#f59e0b,#fcd34d); }
    .kpi-card.red::before    { background: linear-gradient(90deg,#ef4444,#f87171); }
    .kpi-card.cyan::before   { background: linear-gradient(90deg,#06b6d4,#67e8f9); }
    .kpi-card:hover { transform: translateY(-2px); box-shadow: 0 8px 25px rgba(0,0,0,.4); }

    /* ── Feature Panel base ── */
    .feature-panel {
      background: rgba(15,23,42,0.95);
      border: 1px solid rgba(148,163,184,0.15);
      border-radius: 14px;
      backdrop-filter: blur(10px);
    }

    /* ── Premium Feature Tabs ── */
    .prem-tab {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 7px 14px; border-radius: 9px;
      font-size: 0.75rem; font-weight: 600;
      cursor: pointer; transition: all .18s;
      border: 1px solid transparent; white-space: nowrap;
    }
    .prem-tab.active {
      background: rgba(99,102,241,0.2);
      border-color: rgba(99,102,241,0.5);
      color: #a5b4fc;
    }
    .prem-tab:not(.active) {
      background: rgba(255,255,255,0.04);
      border-color: rgba(255,255,255,0.08);
      color: #9ca3af;
    }
    .prem-tab:not(.active):hover {
      background: rgba(255,255,255,0.08);
      color: #e5e7eb;
    }

    /* ── AI Insight Cards ── */
    .insight-card {
      background: rgba(99,102,241,0.08);
      border: 1px solid rgba(99,102,241,0.2);
      border-radius: 10px; padding: 12px 14px;
      font-size: 0.8rem; line-height: 1.6;
      color: #c7d2fe;
      transition: border-color .15s;
    }
    .insight-card:hover { border-color: rgba(99,102,241,0.5); }
    .insight-card .ins-icon { font-size: 1rem; margin-right: 6px; }
    .insight-card .ins-badge {
      display: inline-block;
      background: rgba(99,102,241,0.25);
      color: #a5b4fc; border-radius: 4px;
      padding: 1px 6px; font-size: 0.7rem;
      font-weight: 600; margin-right: 4px;
    }

    /* ── Alert Builder ── */
    .alert-rule {
      background: rgba(30,41,59,0.8);
      border: 1px solid rgba(148,163,184,0.12);
      border-radius: 10px; padding: 12px;
      transition: border-color .15s;
    }
    .alert-rule:hover { border-color: rgba(148,163,184,0.25); }
    .alert-rule.triggered { border-color: rgba(239,68,68,0.5); background: rgba(239,68,68,0.06); }
    .alert-rule.triggered .alert-status { color: #f87171; }
    .alert-rule.ok .alert-status { color: #34d399; }

    .alert-badge {
      position: fixed; top: 72px; right: 20px;
      background: rgba(239,68,68,0.95);
      border: 1px solid rgba(239,68,68,0.6);
      border-radius: 10px; padding: 10px 14px;
      font-size: 0.8rem; color: #fff;
      z-index: 999; max-width: 300px;
      box-shadow: 0 8px 24px rgba(239,68,68,0.3);
      animation: slideIn .3s ease;
    }
    @keyframes slideIn { from { opacity:0; transform:translateX(40px); } to { opacity:1; transform:none; } }

    /* ── Key Influencers ── */
    .influencer-bar-bg {
      background: rgba(55,65,81,0.6);
      border-radius: 4px; height: 8px; overflow: hidden; flex: 1;
    }
    .influencer-bar-fill { height: 100%; border-radius: 4px; transition: width 1s ease; }
    .influencer-row { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
    .influencer-label { font-size: 0.75rem; color: #d1d5db; width: 120px; flex-shrink: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .influencer-val { font-size: 0.7rem; color: #9ca3af; width: 45px; text-align: right; flex-shrink: 0; font-family: monospace; }
    .influencer-dir { font-size: 0.75rem; width: 18px; flex-shrink: 0; text-align: center; }

    /* ── Embed Panel ── */
    .embed-code-box {
      background: #0d1117;
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 9px; padding: 12px 14px;
      font-family: 'Courier New', monospace;
      font-size: 0.7rem; color: #e6edf3;
      line-height: 1.6; overflow-x: auto;
      max-height: 120px; overflow-y: auto;
    }

    /* ── Report Builder ── */
    .report-template {
      background: rgba(30,41,59,0.7);
      border: 1px solid rgba(148,163,184,0.12);
      border-radius: 10px; padding: 12px;
      cursor: pointer; transition: all .18s;
      text-align: center;
    }
    .report-template:hover, .report-template.selected {
      border-color: rgba(99,102,241,0.5);
      background: rgba(99,102,241,0.1);
    }
    .report-template .rt-icon { font-size: 1.6rem; margin-bottom: 6px; }
    .report-template .rt-name { font-size: 0.75rem; font-weight: 600; color: #e5e7eb; }
    .report-template .rt-desc { font-size: 0.65rem; color: #9ca3af; margin-top: 2px; }

    /* ── Data Pipeline ── */
    .pipeline-step {
      display: flex; align-items: center; gap: 10px;
      background: rgba(30,41,59,0.8);
      border: 1px solid rgba(148,163,184,0.12);
      border-radius: 8px; padding: 10px 12px;
      font-size: 0.78rem;
    }
    .pipeline-step .ps-icon { font-size: 1rem; flex-shrink: 0; }
    .pipeline-step .ps-label { color: #d1d5db; flex: 1; }
    .pipeline-step .ps-tag {
      background: rgba(16,185,129,0.15); border: 1px solid rgba(16,185,129,0.3);
      color: #34d399; border-radius: 4px; padding: 1px 6px; font-size: 0.65rem;
    }
    .pipeline-connector { width: 2px; height: 14px; background: rgba(148,163,184,0.2); margin: 0 auto; }

    /* ── NL Chart suggestion ── */
    .nl-chart-suggestion {
      background: rgba(59,130,246,0.1);
      border: 1px solid rgba(59,130,246,0.25);
      border-radius: 8px; padding: 8px 12px;
      font-size: 0.75rem; color: #93c5fd;
      margin-top: 8px; cursor: pointer;
      transition: all .15s;
    }
    .nl-chart-suggestion:hover { background: rgba(59,130,246,0.2); }

    /* ── Slicer, Q&A chips ── */
    #slicerPanel { background: rgba(15,23,42,0.95); border: 1px solid rgba(148,163,184,0.15); border-radius: 12px; backdrop-filter: blur(10px); }
    .slicer-chip { display: inline-flex; align-items: center; gap: 4px; background: rgba(59,130,246,0.2); border: 1px solid rgba(59,130,246,0.4); color: #93c5fd; border-radius: 20px; padding: 3px 10px; font-size: 0.72rem; cursor: pointer; transition: all .15s; }
    .slicer-chip:hover, .slicer-chip.active { background: rgba(59,130,246,0.5); border-color: #3b82f6; color: #fff; }
    .qa-chip { display: inline-block; background: rgba(99,102,241,0.15); border: 1px solid rgba(99,102,241,0.3); color: #a5b4fc; border-radius: 20px; padding: 4px 12px; font-size: 0.72rem; cursor: pointer; transition: all .15s; white-space: nowrap; }
    .qa-chip:hover { background: rgba(99,102,241,0.35); border-color: #6366f1; color: #fff; }

    /* ── Misc ── */
    .profile-bar-bg { background: rgba(55,65,81,0.6); border-radius: 4px; height: 6px; overflow: hidden; }
    .profile-bar-fill { height: 100%; border-radius: 4px; transition: width .6s ease; }
    .cf-high { background: rgba(16,185,129,0.18) !important; color: #34d399 !important; }
    .cf-mid  { background: rgba(245,158,11,0.18) !important; color: #fcd34d !important; }
    .cf-low  { background: rgba(239,68,68,0.18)  !important; color: #f87171 !important; }
    .chart-wrapper { position: relative; background: rgba(15,23,42,0.8); border: 1px solid rgba(148,163,184,0.1); border-radius: 12px; padding: 16px; }
    tr.cross-highlight td { background: rgba(59,130,246,0.12) !important; }
    [data-tip] { position: relative; }
    [data-tip]::after { content: attr(data-tip); position: absolute; bottom: calc(100% + 6px); left: 50%; transform: translateX(-50%); background: #1e293b; color: #e2e8f0; font-size: .7rem; white-space: nowrap; padding: 4px 8px; border-radius: 6px; pointer-events: none; opacity: 0; transition: opacity .15s; border: 1px solid rgba(148,163,184,.2); z-index: 50; }
    [data-tip]:hover::after { opacity: 1; }
    ::-webkit-scrollbar { width: 6px; height: 6px; }
    ::-webkit-scrollbar-track { background: #1e293b; }
    ::-webkit-scrollbar-thumb { background: #475569; border-radius: 3px; }

    /* ── Premium Badge ── */
    .premium-badge {
      display: inline-flex; align-items: center; gap: 3px;
      background: linear-gradient(90deg, rgba(245,158,11,0.2), rgba(251,191,36,0.15));
      border: 1px solid rgba(245,158,11,0.35);
      color: #fcd34d; border-radius: 5px;
      padding: 1px 6px; font-size: 0.63rem; font-weight: 700;
      letter-spacing: .03em;
    }

    @media (max-width: 768px) { button, input, select, textarea { min-height: 44px; } .kpi-grid { grid-template-columns: repeat(2,1fr) !important; } }
    @media (max-width: 480px) { .kpi-grid { grid-template-columns: 1fr !important; } }
  </style>
</head>

<body class="bg-gray-900 antialiased text-gray-100">

  <!-- ── Alert Toast Container ── -->
  <div id="alertToastContainer"></div>

  <!-- ── Header ── -->
  <header class="fixed top-0 left-0 right-0 z-50 bg-gray-900/80 backdrop-blur border-b border-gray-800">
    <div class="w-full mx-auto px-6 lg:px-12 py-4 flex justify-between items-center">
      <h1 class="text-2xl font-bold text-white">
        <a href="/home" class="flex items-center gap-2 text-sky-400 hover:text-sky-300 transition">
          <svg class="w-7 h-7" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <linearGradient id="lg1" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" style="stop-color:#3b82f6"/><stop offset="50%" style="stop-color:#6366f1"/><stop offset="100%" style="stop-color:#8b5cf6"/></linearGradient>
              <linearGradient id="lg2" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" style="stop-color:#60a5fa"/><stop offset="100%" style="stop-color:#a78bfa"/></linearGradient>
            </defs>
            <path d="M50 5 L85 25 L85 75 L50 95 L15 75 L15 25 Z" fill="none" stroke="url(#lg1)" stroke-width="3"/>
            <circle cx="50" cy="50" r="15" fill="url(#lg1)"/>
            <circle cx="50" cy="35" r="3" fill="#60a5fa"/><circle cx="65" cy="42" r="3" fill="#818cf8"/><circle cx="65" cy="58" r="3" fill="#a78bfa"/>
            <circle cx="50" cy="65" r="3" fill="#c084fc"/><circle cx="35" cy="58" r="3" fill="#818cf8"/><circle cx="35" cy="42" r="3" fill="#60a5fa"/>
            <line x1="50" y1="35" x2="65" y2="42" stroke="#60a5fa" stroke-width="1.5" opacity="0.7"/>
            <line x1="65" y1="42" x2="65" y2="58" stroke="#818cf8" stroke-width="1.5" opacity="0.7"/>
            <line x1="65" y1="58" x2="50" y2="65" stroke="#a78bfa" stroke-width="1.5" opacity="0.7"/>
            <line x1="50" y1="65" x2="35" y2="58" stroke="#c084fc" stroke-width="1.5" opacity="0.7"/>
            <line x1="35" y1="58" x2="35" y2="42" stroke="#818cf8" stroke-width="1.5" opacity="0.7"/>
            <line x1="35" y1="42" x2="50" y2="35" stroke="#60a5fa" stroke-width="1.5" opacity="0.7"/>
          </svg>
          VizChat
        </a>
      </h1>
      <div class="flex gap-3 items-center">
        <span id="botUsername" class="text-gray-300 text-sm"></span>
        <div id="alertCountBadge" class="hidden px-2 py-0.5 bg-red-600 text-white text-xs rounded-full font-bold">0</div>
        <a href="/home" class="bg-sky-500 text-white font-semibold px-4 py-2 rounded-lg hover:bg-sky-600 transition text-sm">Home</a>
      </div>
    </div>
  </header>

  <main class="pt-20 pb-10 min-h-screen max-w-screen-2xl mx-auto px-3 sm:px-4 lg:px-12">

    <!-- Title -->
    <div class="mb-4">
      <div class="flex items-center justify-between flex-wrap gap-2">
        <div>
          <h2 class="text-2xl sm:text-3xl font-bold text-white mb-1">Data-Driven Chatbot Builder</h2>
          <p class="text-gray-400 text-sm">Power BI–style analytics · Upload · Explore · Chat · AI Insights</p>
        </div>
        <div class="flex items-center gap-2">
          <span class="premium-badge">⭐ PREMIUM FEATURES</span>
          <span class="text-xs text-gray-500">8 Power BI features unlocked</span>
        </div>
      </div>
    </div>

    <!-- ══ ROW 1 — Upload + Chat ══ -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-4">

      <!-- Upload & Preview -->
      <div class="bg-gray-800 rounded-xl border border-gray-700 p-4 sm:p-6 flex flex-col">
        <h3 class="text-lg font-bold text-white mb-3">📁 Upload Data</h3>
        <div id="dropZone" class="border-2 border-dashed border-gray-600 rounded-xl p-6 text-center hover:border-sky-500 transition cursor-pointer mb-4">
          <svg class="w-10 h-10 text-gray-400 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/>
          </svg>
          <p class="text-gray-300 font-medium text-sm">Drag and drop your file</p>
          <p class="text-gray-500 text-xs">or click to browse · CSV, Excel, JSON</p>
          <input type="file" id="fileInput" class="hidden" accept=".csv,.xlsx,.xls,.json">
        </div>

        <div id="dataStats" class="hidden grid grid-cols-3 gap-2 mb-4">
          <div class="kpi-card blue text-center"><div class="text-2xl font-bold text-sky-400" id="statRows">0</div><div class="text-xs text-gray-400 mt-1">Rows</div></div>
          <div class="kpi-card green text-center"><div class="text-2xl font-bold text-green-400" id="statColumns">0</div><div class="text-xs text-gray-400 mt-1">Columns</div></div>
          <div class="kpi-card purple text-center"><div class="text-2xl font-bold text-purple-400" id="statSize">0KB</div><div class="text-xs text-gray-400 mt-1">Size</div></div>
        </div>

        <div id="activeFilterBadge" class="hidden mb-3 flex items-center gap-2 flex-wrap">
          <span class="text-xs text-gray-400">Active filters:</span>
          <div id="filterChips" class="flex flex-wrap gap-1"></div>
          <button id="clearAllFilters" class="text-xs text-red-400 hover:text-red-300 underline ml-auto">Clear all</button>
        </div>

        <div class="flex justify-between items-center mb-2">
          <h3 class="text-base font-bold text-white">Data Preview</h3>
          <input type="text" id="tableSearch" placeholder="🔍 Search..." class="bg-gray-700 text-white rounded-lg px-3 py-1 text-xs placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-sky-500 hidden w-36 sm:w-48"/>
        </div>
        <div id="dataPreview" class="overflow-auto flex-1 rounded-lg" style="max-height:280px;"><p class="text-gray-400 text-sm">No data uploaded yet.</p></div>
        <p id="rowCount" class="text-xs text-gray-500 mt-2"></p>
      </div>

      <!-- Chat -->
      <div class="bg-gray-800 rounded-xl border border-gray-700 flex flex-col" style="min-height:450px;">
        <div class="border-b border-gray-700 p-4 flex-shrink-0">
          <div class="flex items-center justify-between">
            <div>
              <h3 class="text-xl font-bold text-white">💬 Chat with Your Data</h3>
              <p class="text-gray-400 text-xs mt-1">NL queries · auto-chart · drill-down</p>
            </div>
            <span class="premium-badge">⭐ NL→Chart</span>
          </div>
        </div>
        <div id="qaChips" class="hidden px-4 pt-3 flex flex-wrap gap-2 pb-1 flex-shrink-0 overflow-x-auto"></div>
        <div id="chatMessages" class="flex-1 overflow-y-auto p-4 space-y-3 min-h-[220px] max-h-[320px] bg-gray-800/50">
          <div class="text-center text-gray-400 text-sm mt-10">
            <p>📤 Upload data to start chatting</p>
            <p class="text-xs text-gray-500 mt-2">Ask: "Show bar chart of Sales" · "Who are the top 5?" · "Average price?"</p>
          </div>
        </div>
        <div class="border-t border-gray-700 p-4 bg-gray-800 flex-shrink-0">
          <form id="chatForm" class="flex gap-2">
            <input type="text" id="chatInput" placeholder="Ask anything about your data..." class="flex-1 bg-gray-700 text-white rounded-lg px-4 py-2.5 text-sm placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-sky-500"/>
            <button type="submit" id="sendBtn" class="bg-sky-500 text-white font-semibold px-5 py-2.5 rounded-lg hover:bg-sky-600 transition flex items-center gap-2 text-sm">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M10.894 2.553a1 1 0 00-1.788 0l-7 14a1 1 0 001.169 1.409l5.951-1.429 5.951 1.429a1 1 0 001.169-1.409l-7-14z"/></svg>
              Send
            </button>
          </form>
        </div>
      </div>
    </div>

    <!-- ══ KPI Dashboard ══ -->
    <div id="kpiSection" class="hidden mb-4">
      <div class="flex items-center justify-between mb-3">
        <h3 class="text-lg font-bold text-white">📊 KPI Dashboard</h3>
        <span class="text-xs text-gray-500">Auto-generated from your data</span>
      </div>
      <div id="kpiCards" class="kpi-grid grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3"></div>
    </div>

    <!-- ══ PREMIUM FEATURES TABS ══ -->
    <div id="premiumSection" class="hidden mb-4">
      <div class="flex items-center gap-2 mb-3 flex-wrap">
        <span class="text-sm font-bold text-white mr-2">⭐ Premium Features</span>
        <button class="prem-tab active" data-tab="insights">✨ AI Insights</button>
        <button class="prem-tab" data-tab="alerts">🔔 Alerts</button>
        <button class="prem-tab" data-tab="influencers">🔑 Key Influencers</button>
        <button class="prem-tab" data-tab="pipeline">🔄 Data Pipeline</button>
        <button class="prem-tab" data-tab="report">📄 Report Builder</button>
        <button class="prem-tab" data-tab="embed">🌐 Embed</button>
        <button class="prem-tab" data-tab="rls">🔐 Row-Level Security</button>
        <button class="prem-tab" data-tab="versions">📦 Versions</button>
      </div>

      <!-- ── 1. AI INSIGHTS ── -->
      <div id="tab-insights" class="tab-content feature-panel p-5">
        <div class="flex items-center justify-between mb-4">
          <div>
            <h4 class="text-base font-bold text-white">✨ AI Smart Narratives</h4>
            <p class="text-xs text-gray-400 mt-0.5">Auto-generated insights from your dataset — like Power BI's Smart Narratives (Premium only)</p>
          </div>
          <button id="refreshInsightsBtn" class="bg-indigo-700 hover:bg-indigo-600 text-white px-4 py-2 rounded-lg text-xs font-semibold transition">↻ Refresh</button>
        </div>
        <div id="insightsGrid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3">
          <p class="text-gray-500 text-sm col-span-3">Upload data to generate AI insights.</p>
        </div>
        <!-- Anomaly section -->
        <div id="anomalySection" class="hidden mt-4 pt-4 border-t border-gray-700">
          <h5 class="text-sm font-bold text-amber-400 mb-3">⚠️ Anomaly Detection</h5>
          <div id="anomalyList" class="flex flex-col gap-2"></div>
        </div>
      </div>

      <!-- ── 2. ALERTS ── -->
      <div id="tab-alerts" class="tab-content hidden feature-panel p-5">
        <div class="flex items-center justify-between mb-4">
          <div>
            <h4 class="text-base font-bold text-white">🔔 Data-Driven Alerts</h4>
            <p class="text-xs text-gray-400 mt-0.5">Set threshold alerts on your metrics — like Power BI's Data Alerts (Pro)</p>
          </div>
          <button id="addAlertBtn" class="bg-green-700 hover:bg-green-600 text-white px-4 py-2 rounded-lg text-xs font-semibold transition">+ Add Alert</button>
        </div>

        <!-- Add Alert Form -->
        <div id="alertForm" class="hidden bg-gray-900/70 rounded-xl border border-gray-700 p-4 mb-4">
          <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-3">
            <div>
              <label class="text-xs text-gray-400 mb-1 block">Column</label>
              <select id="alertColumn" class="w-full bg-gray-700 text-white rounded-lg px-3 py-2 text-xs focus:outline-none focus:ring-2 focus:ring-sky-500"><option value="">Select column</option></select>
