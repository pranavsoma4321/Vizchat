document.getElementById('generateEmbedBtn').addEventListener('click', generateEmbed);

function generateEmbed() {
  const type = document.getElementById('embedType').value;
  const access = document.getElementById('embedAccess').value;
  const width = document.getElementById('embedWidth').value || '100%';
  const showChat = document.getElementById('embedShowChat').checked;
  const showCharts = document.getElementById('embedShowCharts').checked;
  const showKpi = document.getElementById('embedShowKpi').checked;
  const darkMode = document.getElementById('embedDarkMode').checked;
  const botName = uploadedFile?.name?.replace(/\.[^/.]+$/, '') || 'DataBot';
  const token = btoa(`${botName}:${access}:${Date.now()}`).substring(0,24);
  const baseUrl = `${window.location.origin}/embed/${token}`;
  const params = new URLSearchParams({ chat: showChat, charts: showCharts, kpi: showKpi, dark: darkMode, access }).toString();
  let code = '';

  if (type === 'iframe') {
    code = `<!-- VizChat Embed: ${botName} -->\n<iframe\n  src="${baseUrl}?${params}"\n  width="${width}"\n  height="600"\n  frameborder="0"\n  allow="clipboard-write"\n  style="border-radius:12px;border:1px solid #e2e8f0"\n  title="${botName} - VizChat"\n></iframe>`;
  } else if (type === 'js') {
    code = `<!-- VizChat SDK -->\n<div id="vizchat-${token}"></div>\n<script src="${window.location.origin}/sdk/vizchat.js"><\/script>\n<script>\n  VizChat.init({\n    container: '#vizchat-${token}',\n    token: '${token}',\n    config: {\n      chat: ${showChat},\n      charts: ${showCharts},\n      kpi: ${showKpi},\n      dark: ${darkMode},\n      access: '${access}'\n    }\n  });\n<\/script>`;
  } else if (type === 'react') {
    code = `import { VizChatEmbed } from '@vizchat/react';\n\nexport function MyDashboard() {\n  return (\n    <VizChatEmbed\n      token="${token}"\n      width="${width}"\n      showChat={${showChat}}\n      showCharts={${showCharts}}\n      showKpi={${showKpi}}\n      darkMode={${darkMode}}\n      access="${access}"\n    />\n  );\n}`;
  } else {
    code = `${baseUrl}?${params}\n\nShare this link to give others ${access === 'view' ? 'view-only' : access === 'interact' ? 'interactive' : 'full'} access to your dashboard.`;
  }

  document.getElementById('embedCodeBox').textContent = code;
  document.getElementById('embedOutput').classList.remove('hidden');
}

