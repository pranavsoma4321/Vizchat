function buildQAChips() {
  if (!currentData.length) return;
  const headers = Object.keys(currentData[0]);
  const numCol = headers.find(h=>currentData.slice(0,20).some(r=>!isNaN(parseFloat(r[h]))&&r[h]!==''));
  const catCol = headers.find(h=>{ const u=new Set(currentData.map(r=>r[h])); return u.size<=20; });
  const suggestions = [
    'How many rows?', 'Show all columns',
    numCol ? `Total ${numCol}` : null, numCol ? `Average ${numCol}` : null,
    numCol ? `Max ${numCol}` : null, catCol ? `Count by ${catCol}` : null,
    'Top 5 records', 'Show summary',
    numCol ? `Show bar chart of ${numCol}` : null,
    catCol && numCol ? `Show pie chart of ${catCol}` : null,
  ].filter(Boolean);
  const container = document.getElementById('qaChips');
  container.innerHTML = '';
  suggestions.forEach(s => {
    const chip = document.createElement('span'); chip.className = 'qa-chip'; chip.textContent = s;
    chip.addEventListener('click', () => { chatInput.value = s; chatForm.dispatchEvent(new Event('submit')); });
    container.appendChild(chip);
  });
  container.classList.remove('hidden');
}

