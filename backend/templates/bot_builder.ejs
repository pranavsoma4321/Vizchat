document.getElementById('runPipelineBtn').addEventListener('click', runDataPipeline);

function runDataPipeline() {
  const input = document.getElementById('pipelineInput').value.trim().toLowerCase();
  if (!input) { alert('Describe a transformation first.'); return; }
  if (!currentData.length) { alert('Upload data first.'); return; }

  const steps = [];
  const log = [];
  let data = [...rawData];

  // Parse NL into pipeline steps
  if (/remove empty|drop null|remove null|drop empty/.test(input)) {
    steps.push({ icon: '🧹', label: 'Remove empty rows', tag: 'Clean' });
    const before = data.length;
    data = data.filter(row => Object.values(row).some(v => v !== '' && v !== null));
    log.push(`✓ Removed ${before - data.length} empty rows. ${data.length} remaining.`);
  }

  if (/remove duplicate|drop duplicate|deduplicate/.test(input)) {
    steps.push({ icon: '🔁', label: 'Remove duplicate rows', tag: 'Deduplicate' });
    const before = data.length;
    const seen = new Set();
    data = data.filter(row => { const k = JSON.stringify(row); if (seen.has(k)) return false; seen.add(k); return true; });
    log.push(`✓ Removed ${before - data.length} duplicates. ${data.length} remaining.`);
  }

  if (/normalize|standardize/.test(input)) {
    const headers = Object.keys(data[0] || {});
    const numCols = headers.filter(h => data.slice(0,10).some(r => !isNaN(parseFloat(r[h])) && r[h] !== ''));
    if (numCols.length) {
      steps.push({ icon: '⚖️', label: `Normalize ${numCols.slice(0,3).join(', ')}`, tag: 'Transform' });
      numCols.forEach(col => {
        const vals = data.map(r => parseFloat(r[col])).filter(v => !isNaN(v));
        const min = Math.min(...vals), max = Math.max(...vals);
        if (max > min) data = data.map(r => { const v = parseFloat(r[col]); return { ...r, [col]: isNaN(v) ? r[col] : ((v-min)/(max-min)).toFixed(4) }; });
      });
      log.push(`✓ Normalized ${numCols.length} numeric column(s) to [0, 1] range.`);
    }
  }

  const filterMatch = input.match(/filter where (.+?)(?:,|$)/);
  if (filterMatch) {
    const filterExpr = filterMatch[1].trim();
    const headers = Object.keys(data[0] || {});
    const colMatch = headers.find(h => filterExpr.includes(h.toLowerCase()));
    const numMatch = filterExpr.match(/([><=!]+)\s*([\d.]+)/);
    if (colMatch && numMatch) {
      const [, op, val] = numMatch; const threshold = parseFloat(val);
      steps.push({ icon: '🔽', label: `Filter: ${colMatch} ${op} ${val}`, tag: 'Filter' });
      const before = data.length;
      const ops = { '>': (a,b)=>a>b, '<': (a,b)=>a<b, '>=': (a,b)=>a>=b, '<=': (a,b)=>a<=b, '=': (a,b)=>a===b, '==': (a,b)=>a===b };
      data = data.filter(r => { const v = parseFloat(r[colMatch]); return !isNaN(v) && (ops[op] || (()=>true))(v, threshold); });
      log.push(`✓ Filtered ${colMatch} ${op} ${val}: ${data.length} rows kept (${before - data.length} removed).`);
    }
  }

  const renameMatch = input.match(/rename ['"']?(\w+)['"']? to ['"']?(\w+)['"']?/);
  if (renameMatch) {
    const [, from, to] = renameMatch;
    const headers = Object.keys(data[0] || {});
    const srcCol = headers.find(h => h.toLowerCase() === from.toLowerCase());
    if (srcCol) {
      steps.push({ icon: '✏️', label: `Rename: ${srcCol} → ${to}`, tag: 'Rename' });
      data = data.map(r => { const row = { ...r }; row[to] = row[srcCol]; delete row[srcCol]; return row; });
      log.push(`✓ Renamed column "${srcCol}" to "${to}".`);
    }
  }

  if (/sort by|order by/.test(input)) {
    const headers = Object.keys(data[0] || {});
    const sortColMatch = headers.find(h => input.includes(h.toLowerCase()));
    if (sortColMatch) {
      const desc = /desc/.test(input);
      steps.push({ icon: '🔀', label: `Sort by ${sortColMatch} ${desc?'↓':'↑'}`, tag: 'Sort' });
      data.sort((a,b) => { const av = parseFloat(a[sortColMatch]), bv = parseFloat(b[sortColMatch]); if (!isNaN(av)&&!isNaN(bv)) return desc ? bv-av : av-bv; return String(a[sortColMatch]).localeCompare(String(b[sortColMatch])) * (desc?-1:1); });
      log.push(`✓ Sorted by "${sortColMatch}" ${desc?'descending':'ascending'}.`);
    }
  }

  if (steps.length === 0) {
    steps.push({ icon: '❓', label: 'No matching transformation found', tag: 'Info' });
    log.push('⚠️ Could not parse transformation. Try: "remove empty rows", "normalize price", "filter where qty > 0", "sort by sales desc".');
  } else {
    currentData = data;
    displayDataPreview(currentData);
    buildKPICards();
    generateAIInsights();
    botStatus.textContent = `Pipeline applied · ${currentData.length} rows`;
    log.push(`\n✅ Pipeline complete. ${currentData.length} rows in output.`);
  }

  // Render steps
  const stepsDiv = document.getElementById('pipelineSteps');
  stepsDiv.innerHTML = steps.map((s, i) => `
    ${i > 0 ? '<div class="pipeline-connector"></div>' : ''}
    <div class="pipeline-step">
      <span class="ps-icon">${s.icon}</span>
      <span class="ps-label">${s.label}</span>
      <span class="ps-tag">${s.tag}</span>
    </div>`).join('');

  // Log
  const logDiv = document.getElementById('pipelineLog');
  logDiv.classList.remove('hidden');
  document.getElementById('pipelineLogContent').innerHTML = log.map(l => `<div>${l}</div>`).join('');
  addChatMessage('bot', `🔄 **Pipeline executed** — ${steps.length} step(s) applied. ${currentData.length} rows remain.\n\n` + log.slice(0,-1).join('\n'));
}

