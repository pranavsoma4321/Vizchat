  </div>`;

  html2pdf().set({
    margin: 10,
    filename: `${title.replace(/\s+/g,'-')}-${Date.now()}.pdf`,
    html2canvas: { scale: 2 },
    jsPDF: { orientation: 'portrait', unit: 'mm', format: 'a4' }
  }).from(reportEl).save();
  botStatus.textContent = 'PDF Report generated ✓';
}

