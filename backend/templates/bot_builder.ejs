    }).join('');
    profileHtml = `<div style="margin-bottom:24px"><h3 style="font-size:14px;font-weight:700;color:#1e293b;margin-bottom:10px;border-left:3px solid #f59e0b;padding-left:10px">Data Profile</h3><table style="width:100%;border-collapse:collapse;font-size:11px"><thead><tr><th style="background:#1e293b;color:#f1f5f9;padding:8px;border:1px solid #334155">Column</th><th style="background:#1e293b;color:#f1f5f9;padding:8px;border:1px solid #334155">Type</th><th style="background:#1e293b;color:#f1f5f9;padding:8px;border:1px solid #334155">Completeness</th><th style="background:#1e293b;color:#f1f5f9;padding:8px;border:1px solid #334155">Unique Values</th></tr></thead><tbody>${profRows}</tbody></table></div>`;
