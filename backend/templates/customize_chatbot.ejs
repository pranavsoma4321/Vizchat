// ─────────────────────────────────────────
//  ANALYTICS ENGINE
// ─────────────────────────────────────────

/**
 * Analyse a bot response and return a rich metrics object.
 * All "AI scores" are derived from real linguistic signals —
 * no random numbers, fully deterministic per response text.
 */
function analyseResponse(text, responseTimeMs, tokenCount) {
  const words = text.trim().split(/\s+/).filter(Boolean);
  const sentences = text.split(/[.!?]+/).filter(s => s.trim().length > 2);
  const wordCount = words.length;
  const sentenceCount = Math.max(sentences.length, 1);

  // ── Hedging detector ──
  const hedgeWords = ['maybe','perhaps','might','could','possibly','i think','i believe','not sure','unclear','uncertain','it seems','it appears','approximately','roughly','about'];
  const hedgeScore = hedgeWords.reduce((acc, h) => acc + (text.toLowerCase().includes(h) ? 1 : 0), 0);

  // ── Confidence: penalise hedging, reward length ──
  const confidenceRaw = Math.max(0, Math.min(100,
    80 - hedgeScore * 8 + Math.min(wordCount / 10, 20)
  ));
  const confidence = Math.round(confidenceRaw);

  // ── Coherence: sentence length consistency ──
  const sentLens = sentences.map(s => s.trim().split(/\s+/).length);
  const avgLen = sentLens.reduce((a,b) => a+b, 0) / sentLens.length;
  const variance = sentLens.reduce((a,b) => a + Math.abs(b - avgLen), 0) / sentLens.length;
  const coherence = Math.round(Math.max(20, Math.min(98, 95 - variance * 2)));

  // ── Complexity: average word length proxy ──
  const avgWordLen = words.reduce((a,w) => a + w.replace(/[^a-zA-Z]/g,'').length, 0) / Math.max(wordCount,1);
  const complexity = Math.round(Math.min(100, (avgWordLen - 3) * 18 + 20));

  // ── Fluency: sentence count / word count ratio ──
  const fluency = Math.round(Math.min(100, Math.max(30,
    100 - Math.abs((wordCount / sentenceCount) - 15) * 3
  )));

  // ── Depth: penalise very short, reward structured responses ──
  const hasList = /^\s*[-*•\d\.]/m.test(text);
  const hasCode = /```|`[^`]+`/.test(text);
  const depth = Math.round(Math.min(100, Math.max(10,
    (Math.log(wordCount + 1) / Math.log(500)) * 70 + (hasList ? 12 : 0) + (hasCode ? 14 : 0)
  )));

  // ── Clarity: short words (<= 6 chars) ratio ──
  const shortWords = words.filter(w => w.replace(/[^a-zA-Z]/g,'').length <= 6).length;
  const clarity = Math.round(Math.min(100, (shortWords / Math.max(wordCount,1)) * 120));

  // ── Sentiment ──
  const posWords = ['great','good','excellent','perfect','helpful','best','easy','simple','sure','yes','absolutely','correct','right','happy','love'];
  const negWords = ['error','fail','wrong','sorry','cannot','unable','problem','issue','bad','unfortunately','no','not','never'];
  const posCount = posWords.reduce((a,w) => a + (text.toLowerCase().includes(w) ? 1 : 0), 0);
  const negCount = negWords.reduce((a,w) => a + (text.toLowerCase().includes(w) ? 1 : 0), 0);
  let sentiment = 'Neutral';
  let sentimentTag = 'blue';
  if (posCount > negCount + 1) { sentiment = 'Positive'; sentimentTag = 'green'; }
  else if (negCount > posCount + 1) { sentiment = 'Cautious'; sentimentTag = 'amber'; }

  // ── Tokens per second ──
  const tps = responseTimeMs > 0 ? Math.round((tokenCount / responseTimeMs) * 1000) : 0;

  // ── Response type tags ──
  const tags = [];
  if (hasCode)  tags.push({ label: '⟨/⟩ Contains Code', cls: 'blue' });
  if (hasList)  tags.push({ label: '≡ Structured', cls: 'purple' });
  if (wordCount > 200) tags.push({ label: '⇥ Detailed', cls: 'green' });
  if (wordCount < 40)  tags.push({ label: '⚡ Concise', cls: 'amber' });
  if (hedgeScore > 2)  tags.push({ label: '? Uncertain', cls: 'amber' });
  if (confidence >= 85) tags.push({ label: '✓ High Confidence', cls: 'green' });
  tags.push({ label: sentiment, cls: sentimentTag });
  if (sentences.some(s => s.includes('?'))) tags.push({ label: '? Clarifying', cls: 'gray' });

  // ── Token frequency bars (50 buckets of word density) ──
  const buckets = 50;
  const bucketSize = Math.max(1, Math.ceil(wordCount / buckets));
  const tokenBars = Array.from({ length: buckets }, (_, i) => {
    const chunk = words.slice(i * bucketSize, (i + 1) * bucketSize);
    return Math.min(100, chunk.length * (100 / bucketSize));
  });

  return {
    responseTime: responseTimeMs,
    tokenCount,
    tps,
    confidence, coherence, complexity, fluency, depth, clarity,
    sentiment, sentimentTag, tags,
    tokenBars,
    wordCount,
    sentenceCount
  };
}

// ─────────────────────────────────────────
//  NEURAL RADAR (Canvas)
// ─────────────────────────────────────────
function drawRadar(canvas, metrics) {
  const size = 96;
  canvas.width = size;
  canvas.height = size;
  const ctx = canvas.getContext('2d');
  const cx = size / 2, cy = size / 2, r = size / 2 - 10;
  const axes = [
    { label: 'Conf', value: metrics.confidence / 100 },
    { label: 'Cohe', value: metrics.coherence / 100 },
    { label: 'Depth', value: metrics.depth / 100 },
    { label: 'Fluency', value: metrics.fluency / 100 },
    { label: 'Clarity', value: metrics.clarity / 100 },
    { label: 'Cmpx', value: Math.min(metrics.complexity, 100) / 100 },
  ];
  const n = axes.length;
  const step = (Math.PI * 2) / n;

  // Grid rings
  [0.25, 0.5, 0.75, 1.0].forEach(scale => {
    ctx.beginPath();
    for (let i = 0; i < n; i++) {
      const angle = i * step - Math.PI / 2;
      const x = cx + Math.cos(angle) * r * scale;
      const y = cy + Math.sin(angle) * r * scale;
      i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
    }
    ctx.closePath();
    ctx.strokeStyle = 'rgba(255,255,255,0.07)';
    ctx.lineWidth = 0.5;
    ctx.stroke();
  });

  // Axis lines
  for (let i = 0; i < n; i++) {
    const angle = i * step - Math.PI / 2;
    ctx.beginPath();
    ctx.moveTo(cx, cy);
    ctx.lineTo(cx + Math.cos(angle) * r, cy + Math.sin(angle) * r);
    ctx.strokeStyle = 'rgba(255,255,255,0.07)';
    ctx.lineWidth = 0.5;
    ctx.stroke();
  }

  // Data polygon — animated fill
  ctx.beginPath();
  for (let i = 0; i < n; i++) {
    const angle = i * step - Math.PI / 2;
    const val = axes[i].value;
    const x = cx + Math.cos(angle) * r * val;
    const y = cy + Math.sin(angle) * r * val;
    i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
  }
  ctx.closePath();
  ctx.fillStyle = 'rgba(56,189,248,0.12)';
  ctx.fill();
  ctx.strokeStyle = 'rgba(56,189,248,0.6)';
  ctx.lineWidth = 1.5;
  ctx.stroke();

  // Data points
  for (let i = 0; i < n; i++) {
    const angle = i * step - Math.PI / 2;
    const val = axes[i].value;
    const x = cx + Math.cos(angle) * r * val;
    const y = cy + Math.sin(angle) * r * val;
    ctx.beginPath();
    ctx.arc(x, y, 2.5, 0, Math.PI * 2);
    ctx.fillStyle = '#38bdf8';
    ctx.fill();
  }

  // Axis labels
  ctx.font = '500 8px "DM Sans", sans-serif';
  ctx.textAlign = 'center';
  ctx.textBaseline = 'middle';
  for (let i = 0; i < n; i++) {
    const angle = i * step - Math.PI / 2;
    const lx = cx + Math.cos(angle) * (r + 9);
    const ly = cy + Math.sin(angle) * (r + 9);
    ctx.fillStyle = 'rgba(120,144,180,0.9)';
    ctx.fillText(axes[i].label, lx, ly);
  }
}

// ─────────────────────────────────────────
//  ANALYTICS PANEL BUILDER
// ─────────────────────────────────────────
function buildAnalyticsPanel(metrics, parentGroup) {
  const panel = document.createElement('div');
  panel.className = 'analytics-panel';

  // Color helper for score
  function scoreColor(v) {
    if (v >= 75) return '#10b981';
    if (v >= 50) return '#38bdf8';
    if (v >= 30) return '#f59e0b';
    return '#ef4444';
  }

  // Format time
  const timeStr = metrics.responseTime >= 1000
    ? (metrics.responseTime / 1000).toFixed(1) + 's'
    : metrics.responseTime + 'ms';

  // Tags HTML
  const tagsHtml = metrics.tags
    .slice(0, 6)
    .map(t => `<span class="ap-tag ${t.cls}">${t.label}</span>`)
    .join('');

  // Token bars HTML
  const barsHtml = metrics.tokenBars.map(h =>
    `<div class="ap-token-bar" style="height:${Math.max(2, h * 0.28)}px"></div>`
  ).join('');

  const dims = [
    { name: 'Confidence', val: metrics.confidence },
    { name: 'Coherence',  val: metrics.coherence  },
    { name: 'Depth',      val: metrics.depth       },
    { name: 'Fluency',    val: metrics.fluency     },
    { name: 'Clarity',    val: metrics.clarity     },
  ];

  const dimsHtml = dims.map(d => `
    <div class="ap-dim-row">
      <span class="ap-dim-name">${d.name}</span>
      <div class="ap-dim-track">
        <div class="ap-dim-fill" style="width:0%;background:${scoreColor(d.val)}" data-target="${d.val}"></div>
      </div>
      <span class="ap-dim-val">${d.val}</span>
    </div>`).join('');

  panel.innerHTML = `
    <div class="ap-header" id="ap-hdr-${currentId}" onclick="toggleAnalytics(this)">
      <div class="ap-header-left">
        <div class="ap-pulse"></div>
        <span class="ap-title">Neural Analytics</span>
      </div>
      <div class="ap-quick-stats">
        <span class="ap-qs-item">⏱ <span>${timeStr}</span></span>
        <span class="ap-qs-item">🔤 <span>${metrics.tokenCount}tok</span></span>
        <span class="ap-qs-item">⚡ <span>${metrics.tps} t/s</span></span>
      </div>
      <svg class="ap-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
      </svg>
    </div>

    <div class="ap-body">
      <!-- Top metric cards -->
      <div class="ap-metrics-row">
        <div class="ap-metric-card">
          <div class="ap-metric-label">Response Time</div>
          <div class="ap-metric-value">${timeStr}</div>
          <div class="ap-metric-sub">${metrics.tps} tokens/sec</div>
          <div class="ap-metric-bar"><div class="ap-metric-bar-fill" style="width:${Math.min(100, 100 - metrics.responseTime/50)}%;background:#38bdf8"></div></div>
        </div>
        <div class="ap-metric-card">
          <div class="ap-metric-label">Token Count</div>
          <div class="ap-metric-value">${metrics.tokenCount}</div>
          <div class="ap-metric-sub">${metrics.sentenceCount} sentences</div>
          <div class="ap-metric-bar"><div class="ap-metric-bar-fill" style="width:${Math.min(100, metrics.tokenCount / 6)}%;background:#a78bfa"></div></div>
        </div>
        <div class="ap-metric-card">
          <div class="ap-metric-label">Confidence</div>
          <div class="ap-metric-value" style="color:${scoreColor(metrics.confidence)}">${metrics.confidence}%</div>
          <div class="ap-metric-sub">${metrics.sentiment} tone</div>
          <div class="ap-metric-bar"><div class="ap-metric-bar-fill" style="width:${metrics.confidence}%;background:${scoreColor(metrics.confidence)}"></div></div>
        </div>
      </div>

      <!-- Radar + Dims -->
      <div class="ap-viz-row">
        <div class="ap-radar-wrap">
          <canvas id="radar-${Date.now()}" width="96" height="96"></canvas>
          <span class="ap-radar-label">Neural Fingerprint</span>
        </div>
        <div class="ap-dims">${dimsHtml}</div>
      </div>

      <!-- Token density stream -->
      <div class="ap-token-stream">
        <div class="ap-token-stream-label">Response Token Density Map</div>
        <div class="ap-token-bars">${barsHtml}</div>
      </div>

      <!-- Tags -->
      <div class="ap-tags-row">${tagsHtml}</div>
    </div>
  `;

  parentGroup.appendChild(panel);

  // Draw radar on next frame
  requestAnimationFrame(() => {
    const canvas = panel.querySelector('canvas');
    if (canvas) drawRadar(canvas, metrics);

    // Animate bars
    panel.querySelectorAll('.ap-dim-fill[data-target]').forEach(el => {
      const target = el.dataset.target;
      setTimeout(() => { el.style.width = target + '%'; }, 80);
    });
    panel.querySelectorAll('.ap-metric-bar-fill').forEach(el => {
      const w = el.style.width;
      el.style.width = '0%';
      setTimeout(() => { el.style.width = w; }, 80);
    });
  });
}

function toggleAnalytics(hdr) {
  hdr.classList.toggle('open');
  const body = hdr.nextElementSibling;
  body.classList.toggle('open');
  hdr.querySelector('.ap-chevron').classList.toggle('open');
}

// ─────────────────────────────────────────
//  MESSAGES
// ─────────────────────────────────────────
function timeStr() {
  return new Date().toLocaleTimeString('en-IN', {hour:'2-digit', minute:'2-digit'});
}

function addMessage(text, role, skipSave = false, metrics = null) {
  const msgs = document.getElementById('messages');
  const welcome = msgs.querySelector('.welcome');
  if (welcome) welcome.remove();

  const group = document.createElement('div');
  group.className = `msg-group ${role}`;

  const avatarHtml = role === 'bot'
    ? `<div class="msg-avatar av-bot"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg></div>`
    : `<div class="msg-avatar av-user">U</div>`;

  group.innerHTML = `
    <div class="msg-row">
      ${avatarHtml}
      <div>
        <div class="bubble">${text}</div>
        <div class="msg-time">${timeStr()}</div>
      </div>
    </div>`;

  msgs.appendChild(group);

  // Syntax highlight + copy buttons for code blocks in bot messages
  if (role === 'bot') {
    const bubble = group.querySelector('.bubble');
    // Parse fenced code blocks
    bubble.innerHTML = bubble.innerHTML
      .replace(/```(\w*)\n?([\s\S]*?)```/g, (_, lang, code) =>
        `<pre data-lang="${lang||'code'}"><code>${code.trimEnd()}</code></pre>`)
      .replace(/`([^`\n]+)`/g, (_, c) => `<code>${c}</code>`);

    // Highlight all pre>code blocks
    bubble.querySelectorAll('pre code').forEach(el => {
      el.innerHTML = highlightCode(el.textContent || el.innerText);
    });

    // Add header bar with lang label + copy button to each pre
    bubble.querySelectorAll('pre').forEach(pre => {
      const lang = pre.dataset.lang || 'code';
      const bar = document.createElement('div');
      bar.style.cssText = [
        'display:flex','align-items:center','justify-content:space-between',
        'padding:5px 12px 5px 14px','background:#161b22',
        'border-bottom:1px solid rgba(255,255,255,.1)',
        'border-radius:8px 8px 0 0','margin:-14px -16px 12px -16px'
      ].join(';');
      bar.innerHTML = `
        <span style="font-family:'JetBrains Mono',monospace;font-size:10.5px;color:#6e7681;text-transform:uppercase;letter-spacing:.07em">${lang}</span>
        <button class="cp-btn" data-done="0"
          style="display:flex;align-items:center;gap:5px;padding:3px 10px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.1);border-radius:5px;color:#8b949e;font-size:11px;cursor:pointer;font-family:'DM Sans',sans-serif;transition:all .2s"
          onmouseover="this.style.color='#eef5ff';this.style.background='rgba(255,255,255,.09)'"
          onmouseout="if(this.dataset.done==='0'){this.style.color='#8b949e';this.style.background='rgba(255,255,255,.04)'}"
          onclick="copyCode(this)">
          <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
          </svg>
          <span>Copy</span>
        </button>`;
      pre.insertBefore(bar, pre.firstChild);
    });
  }

  // Add analytics panel for bot messages
  if (role === 'bot' && metrics) {
    buildAnalyticsPanel(metrics, group);
  }

  msgs.scrollTop = msgs.scrollHeight;
  if (!skipSave) saveChat(text, role);
  updateTitle();
  return group;
}

function addTyping() {
  const msgs = document.getElementById('messages');
  const group = document.createElement('div');
  group.className = 'msg-group bot';
  group.id = 'typingGroup';
  group.innerHTML = `
    <div class="msg-row">
      <div class="msg-avatar av-bot"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg></div>
      <div class="typing-bubble"><div class="td"></div><div class="td"></div><div class="td"></div></div>
    </div>`;
  msgs.appendChild(group);
  msgs.scrollTop = msgs.scrollHeight;
}

function removeTyping() {
  const t = document.getElementById('typingGroup');
  if (t) t.remove();
}

// ─────────────────────────────────────────
//  SAVE / LOAD
// ─────────────────────────────────────────
function saveChat(text, role) {
  if (!chats[currentId]) chats[currentId] = { title: 'New Chat', messages: [], created: Date.now() };
  chats[currentId].messages.push({ text, role, time: Date.now() });
  if (role === 'user' && chats[currentId].title === 'New Chat') {
    chats[currentId].title = text.substring(0, 35) + (text.length > 35 ? '…' : '');
  }
  localStorage.setItem('vc_chatbot_chats', JSON.stringify(chats));
  renderHistory();
  updateTitle();
}

function loadChat(id) {
  currentId = id;
  const msgs = document.getElementById('messages');
  msgs.innerHTML = '';
  const chat = chats[id];
  if (!chat || !chat.messages.length) { showWelcome(); return; }
  chat.messages.forEach(m => addMessage(m.text, m.role, true)); // no analytics on reload
  renderHistory();
  updateTitle();
  closeSidebar();
}

function updateTitle() {
  const chat = chats[currentId];
  if (chat && chat.title !== 'New Chat') {
    document.getElementById('chatTitle').textContent = chat.title.substring(0, 40);
    document.getElementById('chatSub').textContent = `${(chat.messages||[]).length} messages · Local AI`;
  } else {
    document.getElementById('chatTitle').textContent = 'AI Assistant';
    document.getElementById('chatSub').textContent = 'Powered by Ollama · Local';
  }
}

function renderHistory() {
  const now = Date.now();
  const day = 86400000, week = 7*day, month = 30*day;
  const sections = { today: [], week: [], month: [] };

  Object.keys(chats).sort((a,b)=>b-a).forEach(id => {
    const c = chats[id];
    if (!c.messages || !c.messages.length) return;
    const age = now - (c.created || parseInt(id));
    if (age < day) sections.today.push({id, ...c});
    else if (age < week) sections.week.push({id, ...c});
    else if (age < month) sections.month.push({id, ...c});
  });

  function renderSection(containerId, items, label) {
    const c = document.getElementById(containerId);
    c.innerHTML = '';
    if (!items.length) { c.parentElement.style.display = 'none'; return; }
    c.parentElement.style.display = '';
    const lbl = document.createElement('div');
    lbl.className = 'hist-label';
    lbl.textContent = label;
    c.appendChild(lbl);
    items.forEach(item => {
      const div = document.createElement('div');
      div.className = 'hist-item ' + (item.id == currentId ? 'active' : '');
      div.innerHTML = `
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
        <span>${item.title}</span>
        <button class="hist-del" onclick="event.stopPropagation();deleteSingle('${item.id}')"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg></button>`;
      div.addEventListener('click', () => loadChat(item.id));
      c.appendChild(div);
    });
  }

  renderSection('histToday', sections.today, 'Today');
  renderSection('histWeek', sections.week, 'Last 7 days');
  renderSection('histMonth', sections.month, 'Last 30 days');
}

// ─────────────────────────────────────────
//  DELETE / NEW CHAT / CLEAR
// ─────────────────────────────────────────
function deleteSingle(id) {
  delete chats[id];
  localStorage.setItem('vc_chatbot_chats', JSON.stringify(chats));
  if (id == currentId) newChat();
  else renderHistory();
  toast('Chat deleted');
}

function askDeleteAll() { document.getElementById('confirmOverlay').classList.add('show'); }
function closeConfirm() { document.getElementById('confirmOverlay').classList.remove('show'); }
document.getElementById('confirmDelBtn').addEventListener('click', () => {
  chats = {};
  localStorage.removeItem('vc_chatbot_chats');
  closeConfirm();
  newChat();
  toast('All history deleted');
});

function newChat() {
  currentId = Date.now();
  showWelcome();
  renderHistory();
  updateTitle();
  closeSidebar();
}

function clearCurrent() {
  if (chats[currentId]) {
    chats[currentId].messages = [];
    localStorage.setItem('vc_chatbot_chats', JSON.stringify(chats));
  }
  showWelcome();
  toast('Chat cleared');
}

function copyChat() {
  const chat = chats[currentId];
  if (!chat || !chat.messages.length) { toast('Nothing to copy'); return; }
  const txt = chat.messages.map(m => `${m.role==='user'?'You':'AI'}: ${m.text}`).join('\n\n');
  navigator.clipboard.writeText(txt).then(() => toast('Chat copied!')).catch(() => toast('Copy failed'));
}

// ─────────────────────────────────────────
//  SYNTAX HIGHLIGHTER (lightweight, no deps)
// ─────────────────────────────────────────
function highlightCode(code) {
  const esc = s => s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  let s = esc(code);
  const saved = [];
  const save = m => { saved.push(m); return `\x00${saved.length-1}\x00`; };
  const rules = [
    { re: /(\/\*[\s\S]*?\*\/)/g,             cls: 'tok-cmt' },
    { re: /(\/\/[^\n]*)/g,                   cls: 'tok-cmt' },
    { re: /(#[^\n]*)/g,                      cls: 'tok-cmt' },
    { re: /(&quot;(?:[^&]|&amp;|&lt;|&gt;)*?&quot;)/g, cls: 'tok-str' },
    { re: /('(?:[^'\\]|\\.)*?')/g,           cls: 'tok-str' },
    { re: /(`(?:[^`\\]|\\.)*?`)/g,           cls: 'tok-str' },
    { re: /\b(def|class|return|import|from|as|if|elif|else|for|while|in|not|and|or|with|try|except|finally|raise|pass|break|continue|lambda|yield|async|await|True|False|None|function|const|let|var|new|this|typeof|instanceof|export|default|void|null|undefined|switch|case|do|throw|catch|static|extends|super)\b/g, cls: 'tok-kw' },
    { re: /\b(\d+\.?\d*(?:[eE][+-]?\d+)?)\b/g, cls: 'tok-num' },
    { re: /\b([a-zA-Z_]\w*)\s*(?=\()/g,     cls: 'tok-fn'  },
  ];
  rules.forEach(({ re, cls }) => {
    s = s.replace(re, m => save(`<span class="${cls}">${m}</span>`));
  });
  s = s.replace(/\x00(\d+)\x00/g, (_, i) => saved[+i]);
  return s;
}

function applyHighlighting(bubble) {
  bubble.querySelectorAll('pre code').forEach(el => {
    el.innerHTML = highlightCode(el.textContent);
  });
  // bare <pre> without <code> child
  bubble.querySelectorAll('pre:not(:has(code))').forEach(el => {
    el.innerHTML = highlightCode(el.textContent);
  });
}

// ─────────────────────────────────────────
//  SEND MESSAGE — with timing
// ─────────────────────────────────────────
async function sendMessage() {
  const input = document.getElementById('chatInput');
  const text = input.value.trim();
  if (!text || isLoading) return;
  input.value = '';
  autoGrow();
  isLoading = true;
  document.getElementById('sendBtn').disabled = true;

  addMessage(text, 'user');
  addTyping();

  const model = document.getElementById('modelSelect').value;
  const startTime = performance.now();

  try {
    const res = await fetch('http://localhost:11434/api/generate', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ model, prompt: text, num_predict: 600 })
    });

    if (!res.ok) throw new Error('HTTP ' + res.status);

    const reader = res.body.getReader();
    const dec = new TextDecoder();
    let full = '';
    while (true) {
      const { done, value } = await reader.read();
      if (done) break;
      try { const j = JSON.parse(dec.decode(value)); if (j.response) full += j.response; } catch {}
    }

    const responseTimeMs = Math.round(performance.now() - startTime);
    const tokenCount = full.trim().split(/\s+/).filter(Boolean).length;
    const metrics = analyseResponse(full.trim(), responseTimeMs, tokenCount);

    removeTyping();
    addMessage(full.trim() || 'No response from model.', 'bot', false, metrics);

  } catch (err) {
    const responseTimeMs = Math.round(performance.now() - startTime);
    removeTyping();
    const fallback = '⚠️ Cannot reach Ollama. Make sure it\'s running:\n\n`ollama serve`\n\nThen try again.';
    // Show error without analytics
    addMessage(fallback, 'bot');
  }

  isLoading = false;
  document.getElementById('sendBtn').disabled = false;
}

// ─────────────────────────────────────────
//  VOICE INPUT
// ─────────────────────────────────────────
let recognition = null;
const vBtn = document.getElementById('voiceBtn');
if ('webkitSpeechRecognition' in window || 'SpeechRecognition' in window) {
  const SR = window.SpeechRecognition || window.webkitSpeechRecognition;
  recognition = new SR();
  recognition.continuous = false; recognition.interimResults = true; recognition.lang = 'en-US';
  recognition.onresult = e => {
    document.getElementById('chatInput').value = Array.from(e.results).map(r=>r[0].transcript).join('');
    autoGrow();
  };
  recognition.onstart = () => vBtn.classList.add('listening');
  recognition.onend = () => vBtn.classList.remove('listening');
  vBtn.addEventListener('click', () => vBtn.classList.contains('listening') ? recognition.stop() : recognition.start());
} else {
  vBtn.addEventListener('click', () => toast('Voice input not supported — try Chrome'));
}

// ─────────────────────────────────────────
//  TEXTAREA AUTO-GROW
// ─────────────────────────────────────────
function autoGrow() {
  const ta = document.getElementById('chatInput');
  ta.style.height = 'auto';
  ta.style.height = Math.min(ta.scrollHeight, 140) + 'px';
}

document.getElementById('chatInput').addEventListener('input', autoGrow);
document.getElementById('chatInput').addEventListener('keydown', function(e) {
  if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); }
});
document.getElementById('sendBtn').addEventListener('click', sendMessage);

// ─────────────────────────────────────────
//  MOBILE SIDEBAR
// ─────────────────────────────────────────
function openSidebar() { document.getElementById('sidebar').classList.add('open'); document.getElementById('overlay').style.display = 'block'; }
function closeSidebar() { document.getElementById('sidebar').classList.remove('open'); document.getElementById('overlay').style.display = 'none'; }

// ─────────────────────────────────────────
//  COPY CODE BUTTON
// ─────────────────────────────────────────
function copyCode(btn) {
  const pre = btn.closest('pre');
  const code = pre.querySelector('code');
  const raw = (code || pre).innerText;
  navigator.clipboard.writeText(raw).then(() => {
    btn.dataset.done = '1';
    btn.querySelector('span').textContent = 'Copied!';
    btn.style.color = '#4ade80';
    btn.style.background = 'rgba(16,185,129,.08)';
    btn.style.borderColor = 'rgba(16,185,129,.25)';
    setTimeout(() => {
      btn.dataset.done = '0';
      btn.querySelector('span').textContent = 'Copy';
      btn.style.color = '#8b949e';
      btn.style.background = 'rgba(255,255,255,.04)';
      btn.style.borderColor = 'rgba(255,255,255,.1)';
    }, 2000);
  });
}

// ─────────────────────────────────────────
//  INIT
// ─────────────────────────────────────────
showWelcome();
renderHistory();
</script>
</body>
</html>