<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AI Assistant | VizChat</title>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700;800&family=DM+Sans:wght@300;400;500&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --sky: #38bdf8; --sky-dark: #0ea5e9; --indigo: #6366f1; --indigo-mid: #4f46e5;
      --emerald: #10b981; --amber: #f59e0b; --red: #ef4444; --purple: #a78bfa;
      --surface: #060b14; --s2: #0b1019; --s3: #101620; --s4: #161e2e;
      --sidebar: #08101c; --sidebar-2: #0d1624;
      --border: rgba(255,255,255,0.07); --border-mid: rgba(255,255,255,0.11);
      --text: #eef5ff; --text-2: #7a90b4; --text-3: #3b4f6e;
    }

    html, body { height: 100%; background: var(--surface); color: var(--text); font-family: 'DM Sans', sans-serif; font-size: 15px; -webkit-font-smoothing: antialiased; overflow: hidden; }

    .app { display: flex; height: 100vh; overflow: hidden; }

    /* ── Sidebar ── */
    .sidebar { width: 268px; background: var(--sidebar); border-right: 1px solid var(--border); display: flex; flex-direction: column; flex-shrink: 0; transition: transform .3s ease; }
    @media(max-width:768px) { .sidebar { position: fixed; top: 0; left: 0; bottom: 0; z-index: 200; transform: translateX(-100%); } .sidebar.open { transform: translateX(0); } .overlay { display: block !important; } }
    .overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,.5); backdrop-filter: blur(4px); z-index: 190; }

    .sb-hdr { padding: 18px 16px 14px; border-bottom: 1px solid var(--border); flex-shrink: 0; }
    .logo { display: flex; align-items: center; gap: 9px; text-decoration: none; margin-bottom: 14px; }
    .logo-box { width: 34px; height: 34px; background: linear-gradient(135deg, var(--sky-dark), var(--indigo-mid)); border-radius: 9px; display: flex; align-items: center; justify-content: center; box-shadow: 0 0 0 1px rgba(56,189,248,0.2), 0 4px 12px rgba(14,165,233,0.18); flex-shrink: 0; }
    .logo-box svg { width: 17px; height: 17px; color: #fff; }
    .logo-name { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 18px; letter-spacing: -.03em; color: var(--text); }
    .logo-name span { color: var(--sky); }

    .new-chat-btn { display: flex; align-items: center; gap: 8px; width: 100%; padding: 10px 12px; border-radius: 9px; background: linear-gradient(135deg, rgba(14,165,233,.12), rgba(79,70,229,.1)); border: 1px solid rgba(56,189,248,.22); color: var(--sky); font-family: 'DM Sans', sans-serif; font-size: 13px; font-weight: 500; cursor: pointer; transition: all .2s; }
    .new-chat-btn:hover { background: linear-gradient(135deg, rgba(14,165,233,.2), rgba(79,70,229,.15)); }
    .new-chat-btn svg { width: 14px; height: 14px; }

    .model-wrap { padding: 10px 16px; border-bottom: 1px solid var(--border); flex-shrink: 0; }
    .model-label { font-size: 10px; color: var(--text-3); text-transform: uppercase; letter-spacing: .06em; margin-bottom: 6px; }
    .model-select { width: 100%; padding: 8px 11px; background: var(--s3); border: 1px solid var(--border); border-radius: 8px; color: var(--text-2); font-family: 'DM Sans', sans-serif; font-size: 12px; outline: none; cursor: pointer; }
    .model-badge { display: flex; align-items: center; gap: 6px; padding: 4px 9px; border-radius: 6px; background: rgba(16,185,129,.08); border: 1px solid rgba(16,185,129,.18); font-size: 11px; color: #4ade80; margin-top: 6px; }
    .mb-dot { width: 5px; height: 5px; border-radius: 50%; background: #4ade80; animation: pd 2s ease infinite; }
    @keyframes pd { 0%,100%{opacity:1} 50%{opacity:.3} }

    .sb-history { flex: 1; overflow-y: auto; padding: 12px 8px; display: flex; flex-direction: column; gap: 4px; }
    .hist-section { margin-bottom: 10px; }
    .hist-label { font-size: 10px; color: var(--text-3); text-transform: uppercase; letter-spacing: .06em; padding: 0 8px; margin-bottom: 4px; }
    .hist-item { display: flex; align-items: center; gap: 8px; padding: 9px 10px; border-radius: 8px; cursor: pointer; transition: all .15s; font-size: 12.5px; color: var(--text-2); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; border: 1px solid transparent; }
    .hist-item:hover { background: rgba(255,255,255,.05); color: var(--text); }
    .hist-item.active { background: rgba(56,189,248,.07); color: var(--text); border-color: rgba(56,189,248,.18); }
    .hist-item svg { width: 12px; height: 12px; flex-shrink: 0; color: var(--text-3); }
    .hist-item span { overflow: hidden; text-overflow: ellipsis; flex: 1; }
    .hist-del { width: 20px; height: 20px; border-radius: 4px; background: none; border: none; color: var(--text-3); cursor: pointer; display: none; align-items: center; justify-content: center; flex-shrink: 0; transition: all .15s; }
    .hist-del svg { width: 11px; height: 11px; }
    .hist-item:hover .hist-del { display: flex; }
    .hist-del:hover { background: rgba(239,68,68,.1); color: #f87171; }

    .sb-footer { padding: 12px 8px; border-top: 1px solid var(--border); display: flex; flex-direction: column; gap: 6px; flex-shrink: 0; }
    .sb-nav-btn { display: flex; align-items: center; gap: 9px; padding: 9px 10px; border-radius: 8px; font-family: 'DM Sans', sans-serif; font-size: 13px; color: var(--text-2); background: none; border: none; cursor: pointer; transition: all .2s; width: 100%; text-align: left; text-decoration: none; }
    .sb-nav-btn:hover { background: rgba(255,255,255,.05); color: var(--text); }
    .sb-nav-btn svg { width: 14px; height: 14px; flex-shrink: 0; }
    .sb-nav-btn.danger:hover { background: rgba(239,68,68,.08); color: #f87171; }

    /* ── Main ── */
    .main { flex: 1; display: flex; flex-direction: column; overflow: hidden; background: var(--surface); }

    .chat-hdr { display: flex; align-items: center; justify-content: space-between; padding: 0 24px; height: 56px; border-bottom: 1px solid var(--border); background: rgba(6,11,20,0.85); backdrop-filter: blur(16px); flex-shrink: 0; }
    .chat-hdr-left { display: flex; align-items: center; gap: 10px; }
    .hamburger { display: none; background: none; border: none; color: var(--text-2); cursor: pointer; padding: 6px; border-radius: 7px; transition: all .2s; }
    .hamburger:hover { background: rgba(255,255,255,.06); color: var(--text); }
    .hamburger svg { width: 18px; height: 18px; }
    @media(max-width:768px){ .hamburger{display:flex;align-items:center;} }

    .chat-hdr-title { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 16px; letter-spacing: -.02em; color: var(--text); }
    .chat-hdr-sub { font-size: 11.5px; color: var(--text-3); margin-top: 1px; }
    .chat-hdr-right { display: flex; align-items: center; gap: 6px; }
    .hdr-btn { width: 34px; height: 34px; border-radius: 8px; background: rgba(255,255,255,.04); border: 1px solid var(--border); color: var(--text-2); cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all .2s; }
    .hdr-btn:hover { background: rgba(255,255,255,.08); color: var(--text); }
    .hdr-btn svg { width: 15px; height: 15px; }
    .hdr-btn-primary { background: rgba(56,189,248,.08); border-color: rgba(56,189,248,.2); color: var(--sky); }
    .hdr-btn-primary:hover { background: rgba(56,189,248,.14); }

    /* ── Messages ── */
    .messages { flex: 1; overflow-y: auto; padding: 24px 0; display: flex; flex-direction: column; gap: 0; }

    .welcome { display: flex; flex-direction: column; align-items: center; justify-content: center; flex: 1; padding: 40px 24px; text-align: center; animation: fadeUp .5s ease; }
    @keyframes fadeUp { from{opacity:0;transform:translateY(12px)} to{opacity:1;transform:translateY(0)} }
    .welcome-icon { width: 68px; height: 68px; background: linear-gradient(135deg, var(--sky-dark), var(--indigo-mid)); border-radius: 20px; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px; box-shadow: 0 8px 28px rgba(14,165,233,0.22); }
    .welcome-icon svg { width: 34px; height: 34px; color: #fff; }
    .welcome h2 { font-family: 'Syne', sans-serif; font-weight: 700; font-size: clamp(22px, 3vw, 30px); letter-spacing: -.03em; color: var(--text); margin-bottom: 10px; }
    .welcome p { font-size: 14px; color: var(--text-2); max-width: 380px; line-height: 1.7; margin-bottom: 30px; font-weight: 300; }

    .suggest-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; max-width: 520px; width: 100%; }
    @media(max-width:500px){ .suggest-grid{grid-template-columns:1fr} }
    .suggest-chip { padding: 11px 14px; background: var(--s2); border: 1px solid var(--border); border-radius: 11px; text-align: left; cursor: pointer; transition: all .2s; font-family: 'DM Sans', sans-serif; }
    .suggest-chip:hover { border-color: rgba(56,189,248,.35); background: rgba(56,189,248,.05); transform: translateY(-2px); }
    .suggest-chip .sc-icon { font-size: 18px; margin-bottom: 5px; display: block; }
    .suggest-chip .sc-title { font-size: 13px; font-weight: 500; color: var(--text); display: block; margin-bottom: 2px; }
    .suggest-chip .sc-sub { font-size: 11px; color: var(--text-3); }

    .msg-group { padding: 6px 24px 6px; display: flex; flex-direction: column; animation: fadeUp .3s ease; }
    .msg-group.user { align-items: flex-end; }
    .msg-group.bot { align-items: flex-start; }

    .msg-row { display: flex; align-items: flex-start; gap: 10px; max-width: min(72%, 680px); }
    .msg-group.user .msg-row { flex-direction: row-reverse; }

    .msg-avatar { width: 30px; height: 30px; border-radius: 8px; flex-shrink: 0; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 600; margin-top: 2px; }
    .av-bot { background: linear-gradient(135deg, var(--sky-dark), var(--indigo-mid)); color: #fff; }
    .av-user { background: rgba(255,255,255,.08); color: var(--text-2); border: 1px solid var(--border); font-size: 11px; }
    .av-bot svg { width: 15px; height: 15px; color: #fff; }

    .bubble { padding: 11px 15px; border-radius: 14px; font-size: 14px; line-height: 1.65; word-break: break-word; white-space: pre-wrap; }
    .msg-group.bot .bubble { background: var(--s3); border: 1px solid var(--border); color: var(--text); border-top-left-radius: 3px; }
    .msg-group.user .bubble { background: linear-gradient(135deg, rgba(14,165,233,.18), rgba(79,70,229,.14)); border: 1px solid rgba(56,189,248,.2); color: var(--text); border-top-right-radius: 3px; }

    .msg-time { font-size: 10.5px; color: var(--text-3); margin-top: 4px; padding: 0 2px; }

    .typing-bubble { display: flex; gap: 5px; align-items: center; padding: 13px 16px; background: var(--s3); border: 1px solid var(--border); border-radius: 14px; border-top-left-radius: 3px; }
    .td { width: 6px; height: 6px; border-radius: 50%; background: var(--sky); animation: bounce2 1.2s infinite; }
    .td:nth-child(2){animation-delay:.2s} .td:nth-child(3){animation-delay:.4s}
    @keyframes bounce2{0%,60%,100%{transform:translateY(0);opacity:.3}30%{transform:translateY(-4px);opacity:1}}

    .bubble pre {
      background: #0d1117;
      border-radius: 10px;
      padding: 14px 16px;
      overflow-x: auto;
      margin: 10px 0;
      border: 1px solid rgba(255,255,255,.15);
      box-shadow: inset 0 1px 0 rgba(255,255,255,.05);
    }
    .bubble pre code {
      font-family: 'JetBrains Mono', monospace;
      font-size: 13px;
      line-height: 1.7;
      color: #e6edf3;
      background: none;
      padding: 0;
      white-space: pre;
    }
    .bubble code {
      font-family: 'JetBrains Mono', monospace;
      font-size: 13px;
      color: #79c0ff;
      background: rgba(56,189,248,.1);
      border: 1px solid rgba(56,189,248,.2);
      border-radius: 4px;
      padding: 1px 6px;
    }
    /* Syntax-like coloring via CSS class hooks (set by JS parser) */
    .tok-kw  { color: #ff7b72; }
    .tok-str { color: #a5d6ff; }
    .tok-num { color: #f2cc60; }
    .tok-cmt { color: #8b949e; font-style: italic; }
    .tok-fn  { color: #d2a8ff; }
    .tok-op  { color: #79c0ff; }

    /* ── INPUT ── */
    .input-area { border-top: 1px solid var(--border); background: var(--surface); padding: 14px 24px 18px; flex-shrink: 0; }
    .input-wrap { display: flex; align-items: flex-end; gap: 8px; background: var(--s2); border: 1px solid var(--border); border-radius: 14px; padding: 8px 8px 8px 16px; transition: border-color .2s; }
    .input-wrap:focus-within { border-color: rgba(56,189,248,.4); box-shadow: 0 0 0 3px rgba(56,189,248,.06); }
    .chat-textarea { flex: 1; background: none; border: none; color: var(--text); font-family: 'DM Sans', sans-serif; font-size: 14px; outline: none; resize: none; line-height: 1.5; max-height: 140px; min-height: 22px; padding: 3px 0; }
    .chat-textarea::placeholder { color: var(--text-3); }
    .input-actions { display: flex; align-items: flex-end; gap: 5px; flex-shrink: 0; }
    .voice-btn { width: 36px; height: 36px; border-radius: 9px; background: rgba(167,139,250,.08); border: 1px solid rgba(167,139,250,.18); color: var(--purple); cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all .2s; }
    .voice-btn:hover { background: rgba(167,139,250,.16); }
    .voice-btn.listening { background: rgba(239,68,68,.1); border-color: rgba(239,68,68,.3); color: var(--red); animation: pb .8s ease infinite; }
    @keyframes pb { 0%,100%{transform:scale(1)} 50%{transform:scale(1.06)} }
    .voice-btn svg { width: 15px; height: 15px; }
    .send-btn { width: 36px; height: 36px; border-radius: 9px; background: var(--sky-dark); border: none; color: #fff; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all .2s; box-shadow: 0 3px 12px rgba(14,165,233,.25); }
    .send-btn:hover { background: #0284c7; transform: translateY(-1px); }
    .send-btn:disabled { opacity: .4; cursor: not-allowed; transform: none; }
    .send-btn svg { width: 15px; height: 15px; }
    .input-hint { font-size: 11px; color: var(--text-3); margin-top: 6px; text-align: center; }

    /* ══════════════════════════════════════════
       ANALYTICS PANEL — New Feature
    ══════════════════════════════════════════ */
    .analytics-panel {
      margin-top: 8px;
      max-width: min(72%, 680px);
      background: rgba(11,16,25,0.9);
      border: 1px solid rgba(56,189,248,0.12);
      border-radius: 12px;
      overflow: hidden;
      animation: fadeUp .4s ease;
      font-family: 'DM Sans', sans-serif;
    }

    /* Toggle header */
    .ap-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 8px 12px;
      cursor: pointer;
      user-select: none;
      transition: background .15s;
      border-bottom: 1px solid transparent;
    }
    .ap-header:hover { background: rgba(56,189,248,.04); }
    .ap-header.open { border-bottom-color: rgba(56,189,248,.10); }
    .ap-header-left { display: flex; align-items: center; gap: 7px; }
    .ap-pulse { width: 6px; height: 6px; border-radius: 50%; background: var(--sky); animation: pd 2s infinite; flex-shrink: 0; }
    .ap-title { font-size: 11px; font-weight: 500; color: var(--sky); letter-spacing: .04em; text-transform: uppercase; }
    .ap-quick-stats { display: flex; align-items: center; gap: 10px; }
    .ap-qs-item { font-size: 11px; color: var(--text-3); font-family: 'JetBrains Mono', monospace; }
    .ap-qs-item span { color: var(--text-2); }
    .ap-chevron { width: 14px; height: 14px; color: var(--text-3); transition: transform .25s; flex-shrink: 0; }
    .ap-chevron.open { transform: rotate(180deg); }

    /* Body */
    .ap-body {
      display: none;
      padding: 12px;
      gap: 12px;
    }
    .ap-body.open { display: flex; flex-wrap: wrap; }

    /* Metric Cards Row */
    .ap-metrics-row {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 7px;
      width: 100%;
    }
    .ap-metric-card {
      background: rgba(255,255,255,.03);
      border: 1px solid rgba(255,255,255,.06);
      border-radius: 8px;
      padding: 8px 10px;
    }
    .ap-metric-label {
      font-size: 9.5px;
      color: var(--text-3);
      text-transform: uppercase;
      letter-spacing: .05em;
      margin-bottom: 4px;
    }
    .ap-metric-value {
      font-family: 'JetBrains Mono', monospace;
      font-size: 16px;
      font-weight: 500;
      color: var(--text);
      line-height: 1;
    }
    .ap-metric-sub {
      font-size: 10px;
      color: var(--text-3);
      margin-top: 2px;
    }
    .ap-metric-bar {
      height: 3px;
      background: rgba(255,255,255,.06);
      border-radius: 2px;
      margin-top: 6px;
      overflow: hidden;
    }
    .ap-metric-bar-fill {
      height: 100%;
      border-radius: 2px;
      transition: width 1s cubic-bezier(.22,1,.36,1);
    }

    /* Neural Radar + Badges */
    .ap-viz-row {
      display: flex;
      gap: 12px;
      width: 100%;
      align-items: flex-start;
    }

    /* Radar canvas */
    .ap-radar-wrap {
      flex-shrink: 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 4px;
    }
    .ap-radar-wrap canvas {
      display: block;
    }
    .ap-radar-label {
      font-size: 9.5px;
      color: var(--text-3);
      text-transform: uppercase;
      letter-spacing: .05em;
    }

    /* Dimension badges */
    .ap-dims {
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 6px;
    }
    .ap-dim-row {
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .ap-dim-name {
      font-size: 11px;
      color: var(--text-2);
      width: 72px;
      flex-shrink: 0;
    }
    .ap-dim-track {
      flex: 1;
      height: 4px;
      background: rgba(255,255,255,.05);
      border-radius: 2px;
      overflow: hidden;
    }
    .ap-dim-fill {
      height: 100%;
      border-radius: 2px;
      transition: width 1.2s cubic-bezier(.22,1,.36,1);
    }
    .ap-dim-val {
      font-family: 'JetBrains Mono', monospace;
      font-size: 10px;
      color: var(--text-3);
      width: 28px;
      text-align: right;
      flex-shrink: 0;
    }

    /* Tag badges */
    .ap-tags-row {
      display: flex;
      flex-wrap: wrap;
      gap: 5px;
      width: 100%;
    }
    .ap-tag {
      padding: 3px 8px;
      border-radius: 5px;
      font-size: 10.5px;
      font-weight: 500;
      border: 1px solid;
    }
    .ap-tag.green { background: rgba(16,185,129,.08); border-color: rgba(16,185,129,.2); color: #4ade80; }
    .ap-tag.blue  { background: rgba(56,189,248,.08); border-color: rgba(56,189,248,.2); color: var(--sky); }
    .ap-tag.amber { background: rgba(245,158,11,.08); border-color: rgba(245,158,11,.2); color: #fbbf24; }
    .ap-tag.red   { background: rgba(239,68,68,.08); border-color: rgba(239,68,68,.2); color: #f87171; }
    .ap-tag.purple{ background: rgba(167,139,250,.08); border-color: rgba(167,139,250,.2); color: var(--purple); }
    .ap-tag.gray  { background: rgba(255,255,255,.04); border-color: rgba(255,255,255,.1); color: var(--text-3); }

    /* Token stream viz */
    .ap-token-stream {
      width: 100%;
      background: rgba(0,0,0,.2);
      border: 1px solid rgba(255,255,255,.05);
      border-radius: 8px;
      padding: 8px 10px;
    }
    .ap-token-stream-label {
      font-size: 9.5px;
      color: var(--text-3);
      text-transform: uppercase;
      letter-spacing: .05em;
      margin-bottom: 6px;
    }
    .ap-token-bars {
      display: flex;
      gap: 2px;
      align-items: flex-end;
      height: 28px;
    }
    .ap-token-bar {
      flex: 1;
      background: rgba(56,189,248,.25);
      border-radius: 1px 1px 0 0;
      min-height: 2px;
      transition: height .8s ease;
    }

    /* ── TOAST ── */
    .toast { position: fixed; bottom: 80px; left: 50%; transform: translateX(-50%) translateY(60px); opacity: 0; z-index: 500; background: var(--s3); border: 1px solid var(--border-mid); border-radius: 10px; padding: 10px 16px; font-size: 13px; color: var(--text-2); transition: all .3s cubic-bezier(.22,1,.36,1); pointer-events: none; white-space: nowrap; }
    .toast.show { transform: translateX(-50%) translateY(0); opacity: 1; }

    /* ── CONFIRM ── */
    .confirm-overlay { position: fixed; inset: 0; background: rgba(0,0,0,.65); backdrop-filter: blur(6px); z-index: 300; display: none; align-items: center; justify-content: center; padding: 20px; }
    .confirm-overlay.show { display: flex; }
    .confirm-box { background: var(--s2); border: 1px solid rgba(239,68,68,.25); border-radius: 16px; padding: 28px; max-width: 360px; width: 100%; text-align: center; }
    .ci { width: 48px; height: 48px; border-radius: 12px; background: rgba(239,68,68,.1); display: flex; align-items: center; justify-content: center; margin: 0 auto 14px; }
    .ci svg { width: 24px; height: 24px; color: #f87171; }
    .confirm-box h4 { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 17px; color: var(--text); margin-bottom: 7px; }
    .confirm-box p { font-size: 13px; color: var(--text-2); line-height: 1.6; margin-bottom: 18px; }
    .confirm-btns { display: flex; gap: 8px; }
