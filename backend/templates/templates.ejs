  let activeCategory = 'all';
  let searchQ = '';

  // ── Render grid ───────────────────────────
  function render() {
    const grid = document.getElementById('templatesGrid');
    let list = templates;
    if (activeCategory !== 'all') list = list.filter(t => t.category === activeCategory);
    if (searchQ) list = list.filter(t => t.name.toLowerCase().includes(searchQ) || t.desc.toLowerCase().includes(searchQ) || t.category.toLowerCase().includes(searchQ));

    if (!list.length) {
      grid.innerHTML = `<div class="no-results"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg><h3>No templates found</h3><p>Try a different search term or category.</p></div>`;
      return;
    }

    grid.innerHTML = list.map((t, i) => `
      <div class="t-card tc-${t.color}" style="animation-delay:${i*.06}s" id="card-${t.id}">
        <div class="t-icon ti-${t.color}">${t.icon}</div>
        <span class="t-cat tcat-${t.color}">${t.category}</span>
        <h3 class="t-title">${t.name}</h3>
        <p class="t-desc">${t.desc}</p>
        <div class="t-stats">
          ${t.stats.map(s=>`<span class="t-stat">${s}</span>`).join('')}
        </div>

        <!-- Data preview -->
        <div class="t-preview" id="preview-${t.id}">
          <div class="tp-label">Sample data (${t.data.length} rows)</div>
          <div style="overflow-x:auto">
            <table style="width:100%;border-collapse:collapse;font-size:11px">
              <thead>
                <tr>
                  ${t.previewKeys.map(k=>`<th style="text-align:left;padding:3px 6px;color:var(--text-3);font-weight:500;white-space:nowrap">${k}</th>`).join('')}
                </tr>
              </thead>
              <tbody>
                ${t.data.slice(0,4).map(row=>`<tr>${t.previewKeys.map(k=>`<td style="padding:3px 6px;color:var(--text-2);border-top:1px solid rgba(255,255,255,.04);white-space:nowrap;max-width:100px;overflow:hidden;text-overflow:ellipsis">${row[k]!==undefined?row[k]:'—'}</td>`).join('')}</tr>`).join('')}
              </tbody>
            </table>
          </div>
        </div>

        <div class="t-footer">
          <button class="t-explore-btn teb-${t.color}" onclick="loadTemplate('${t.id}')">
            <div class="shine"></div>
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            Start Exploring
          </button>
          <button class="t-peek-btn" id="peek-${t.id}" onclick="togglePreview('${t.id}')" title="Preview data">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </button>
        </div>
      </div>
    `).join('');
  }

  // ── Toggle preview ────────────────────────
  function togglePreview(id) {
    const el = document.getElementById('preview-' + id);
    const btn = document.getElementById('peek-' + id);
    if (!el) return;
    el.classList.toggle('show');
    btn.classList.toggle('open');
  }

  // ── Load template ─────────────────────────
  function loadTemplate(id) {
    const t = templates.find(x => x.id === id);
    if (!t) return;
    sessionStorage.setItem('templateData', JSON.stringify(t.data));
    sessionStorage.setItem('templateName', t.name);

    // Show toast
    document.getElementById('toastMsg').textContent = `Loading "${t.name}"…`;
    document.getElementById('toast').classList.add('show');
    setTimeout(() => {
      window.location.href = '/bot_builder?template=true';
    }, 800);
  }

  // ── Category filter ───────────────────────
  document.querySelectorAll('.cat-btn').forEach(btn => {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.cat-btn').forEach(b => b.classList.remove('on'));
      this.classList.add('on');
      activeCategory = this.dataset.cat;
      render();
    });
  });

  // ── Search ────────────────────────────────
  document.getElementById('searchInput').addEventListener('input', function() {
    searchQ = this.value.toLowerCase().trim();
    render();
  });

  // ── Init ──────────────────────────────────
  render();
</script>
