<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Bot Templates | VizChat</title>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --sky: #38bdf8; --sky-dark: #0ea5e9; --indigo: #6366f1; --indigo-mid: #4f46e5;
      --emerald: #10b981; --amber: #f59e0b; --red: #ef4444; --purple: #a78bfa;
      --pink: #ec4899;
      --surface: #060b14; --s2: #0b1019; --s3: #101620; --s4: #161e2e;
      --border: rgba(255,255,255,0.07); --border-mid: rgba(255,255,255,0.12);
      --text: #eef5ff; --text-2: #7a90b4; --text-3: #3b4f6e;
    }

    html, body { background: var(--surface); color: var(--text); font-family: 'DM Sans', sans-serif; font-size: 15px; -webkit-font-smoothing: antialiased; overflow-x: hidden; }
    body { padding-top: 66px; min-height: 100vh; }

    /* ── BG ── */
    .bg-mesh { position: fixed; inset: 0; z-index: 0; pointer-events: none;
      background: radial-gradient(ellipse 60% 50% at 10% 90%, rgba(56,189,248,0.07) 0%, transparent 55%),
                  radial-gradient(ellipse 50% 45% at 90% 5%,  rgba(99,102,241,0.08) 0%, transparent 55%),
                  radial-gradient(ellipse 45% 40% at 50% 50%, rgba(16,185,129,0.04) 0%, transparent 60%); }
    .bg-grid { position: fixed; inset: 0; z-index: 0; pointer-events: none;
      background-image: linear-gradient(rgba(255,255,255,0.016) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.016) 1px, transparent 1px);
      background-size: 56px 56px;
      mask-image: radial-gradient(ellipse 85% 85% at 50% 40%, black 20%, transparent 80%); }

    /* ── Header ── */
    header { position: fixed; top: 0; left: 0; right: 0; z-index: 100; background: rgba(6,11,20,0.88); backdrop-filter: blur(20px) saturate(180%); border-bottom: 1px solid var(--border); }
    .hdr { max-width: 1400px; margin: 0 auto; padding: 0 24px; height: 66px; display: flex; align-items: center; justify-content: space-between; gap: 16px; }
    .logo { display: flex; align-items: center; gap: 10px; text-decoration: none; }
    .logo-box { width: 36px; height: 36px; background: linear-gradient(135deg, var(--sky-dark), var(--indigo-mid)); border-radius: 10px; display: flex; align-items: center; justify-content: center; box-shadow: 0 0 0 1px rgba(56,189,248,0.2), 0 6px 18px rgba(14,165,233,0.18); flex-shrink: 0; }
    .logo-box svg { width: 18px; height: 18px; color: #fff; }
    .logo-name { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 20px; letter-spacing: -.03em; color: var(--text); }
    .logo-name span { color: var(--sky); }
    .hdr-right { display: flex; align-items: center; gap: 8px; }
    .btn-sm { padding: 7px 14px; border-radius: 8px; font-family: 'DM Sans', sans-serif; font-size: 13px; font-weight: 500; cursor: pointer; border: none; transition: all .2s; text-decoration: none; display: inline-flex; align-items: center; gap: 6px; }
    .btn-sky { background: var(--sky-dark); color: #fff; }
    .btn-sky:hover { background: #0284c7; transform: translateY(-1px); }
    .btn-ghost { background: rgba(255,255,255,0.05); color: var(--text-2); border: 1px solid var(--border); }
    .btn-ghost:hover { background: rgba(255,255,255,0.09); color: var(--text); }

    /* ── Main ── */
    .main { position: relative; z-index: 1; max-width: 1400px; margin: 0 auto; padding: 32px 24px 80px; }

    /* ── Hero header ── */
    .page-hero { text-align: center; padding: 20px 0 48px; }
    .page-eyebrow { display: inline-flex; align-items: center; gap: 7px; padding: 5px 13px; border-radius: 100px; background: rgba(56,189,248,0.08); border: 1px solid rgba(56,189,248,0.18); font-size: 11px; color: var(--sky); font-weight: 500; letter-spacing: .07em; text-transform: uppercase; margin-bottom: 16px; }
    .page-eyebrow-dot { width: 5px; height: 5px; border-radius: 50%; background: var(--sky); animation: pd 2s ease infinite; }
    @keyframes pd { 0%,100%{opacity:1} 50%{opacity:.3} }
    .page-title { font-family: 'Syne', sans-serif; font-weight: 800; font-size: clamp(26px, 4vw, 46px); letter-spacing: -.04em; color: var(--text); margin-bottom: 14px; line-height: 1.08; }
    .page-title .accent { background: linear-gradient(135deg, var(--sky) 10%, var(--indigo) 90%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
    .page-sub { font-size: 15px; color: var(--text-2); line-height: 1.7; max-width: 520px; margin: 0 auto 28px; font-weight: 300; }

    /* ── Search & filter ── */
    .filter-bar { display: flex; align-items: center; gap: 8px; justify-content: center; flex-wrap: wrap; margin-bottom: 40px; }
    .search-wrap { position: relative; }
    .search-wrap svg { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); width: 14px; height: 14px; color: var(--text-3); pointer-events: none; }
    .search-input { padding: 10px 14px 10px 36px; background: var(--s2); border: 1px solid var(--border); border-radius: 10px; color: var(--text); font-family: 'DM Sans', sans-serif; font-size: 13px; outline: none; width: 240px; transition: all .2s; }
    .search-input::placeholder { color: var(--text-3); }
    .search-input:focus { border-color: rgba(56,189,248,.4); width: 280px; }
    .cat-btn { padding: 8px 16px; border-radius: 9px; background: var(--s2); border: 1px solid var(--border); color: var(--text-3); font-family: 'DM Sans', sans-serif; font-size: 12.5px; font-weight: 500; cursor: pointer; transition: all .2s; white-space: nowrap; }
    .cat-btn.on { background: rgba(56,189,248,.09); color: var(--sky); border-color: rgba(56,189,248,.28); }
    .cat-btn:hover:not(.on) { background: rgba(255,255,255,.05); color: var(--text-2); }

    /* ── Templates grid ── */
    .templates-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
    @media(max-width:1100px){ .templates-grid{grid-template-columns:repeat(2,1fr)} }
    @media(max-width:680px){ .templates-grid{grid-template-columns:1fr} }

    /* ── Template card ── */
    .t-card { background: var(--s2); border: 1px solid var(--border); border-radius: 18px; padding: 24px; display: flex; flex-direction: column; gap: 0; position: relative; overflow: hidden; cursor: pointer; transition: all .28s; }
    .t-card:hover { transform: translateY(-5px); border-color: var(--border-mid); box-shadow: 0 16px 36px rgba(0,0,0,0.3); }

    /* Top glow accent */
    .t-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; border-radius: 18px 18px 0 0; transition: opacity .3s; opacity: .6; }
    .t-card:hover::before { opacity: 1; }
    .tc-blue::before   { background: linear-gradient(90deg, #3b82f6, #60a5fa); }
    .tc-purple::before { background: linear-gradient(90deg, #8b5cf6, #a78bfa); }
    .tc-green::before  { background: linear-gradient(90deg, #10b981, #34d399); }
    .tc-red::before    { background: linear-gradient(90deg, #ef4444, #f87171); }
    .tc-amber::before  { background: linear-gradient(90deg, #f59e0b, #fbbf24); }
    .tc-indigo::before { background: linear-gradient(90deg, #6366f1, #818cf8); }

    /* Hover glow background */
    .t-card::after { content: ''; position: absolute; inset: 0; opacity: 0; transition: opacity .3s; pointer-events: none; border-radius: 18px; }
    .t-card:hover::after { opacity: 1; }
    .tc-blue:hover::after   { background: radial-gradient(ellipse 70% 50% at 50% 0%, rgba(59,130,246,0.06) 0%, transparent 70%); }
    .tc-purple:hover::after { background: radial-gradient(ellipse 70% 50% at 50% 0%, rgba(139,92,246,0.06) 0%, transparent 70%); }
    .tc-green:hover::after  { background: radial-gradient(ellipse 70% 50% at 50% 0%, rgba(16,185,129,0.06) 0%, transparent 70%); }
    .tc-red:hover::after    { background: radial-gradient(ellipse 70% 50% at 50% 0%, rgba(239,68,68,0.06) 0%, transparent 70%); }
    .tc-amber:hover::after  { background: radial-gradient(ellipse 70% 50% at 50% 0%, rgba(245,158,11,0.06) 0%, transparent 70%); }
    .tc-indigo:hover::after { background: radial-gradient(ellipse 70% 50% at 50% 0%, rgba(99,102,241,0.06) 0%, transparent 70%); }

    /* Icon */
    .t-icon { width: 50px; height: 50px; border-radius: 13px; display: flex; align-items: center; justify-content: center; margin-bottom: 16px; transition: transform .25s; position: relative; z-index: 1; }
    .t-card:hover .t-icon { transform: scale(1.1); }
    .t-icon svg { width: 24px; height: 24px; }
    .ti-blue   { background: rgba(59,130,246,.12);  color: #60a5fa; }
    .ti-purple { background: rgba(139,92,246,.12);  color: #a78bfa; }
    .ti-green  { background: rgba(16,185,129,.12);  color: #34d399; }
    .ti-red    { background: rgba(239,68,68,.12);   color: #f87171; }
    .ti-amber  { background: rgba(245,158,11,.12);  color: #fbbf24; }
    .ti-indigo { background: rgba(99,102,241,.12);  color: #818cf8; }

    /* Category badge */
    .t-cat { display: inline-flex; align-items: center; gap: 5px; padding: 3px 9px; border-radius: 5px; font-size: 10px; font-weight: 600; letter-spacing: .05em; text-transform: uppercase; margin-bottom: 8px; position: relative; z-index: 1; }
    .tcat-blue   { background: rgba(59,130,246,.1);  color: #93c5fd; border: 1px solid rgba(59,130,246,.2); }
    .tcat-purple { background: rgba(139,92,246,.1);  color: #c4b5fd; border: 1px solid rgba(139,92,246,.2); }
    .tcat-green  { background: rgba(16,185,129,.1);  color: #6ee7b7; border: 1px solid rgba(16,185,129,.2); }
    .tcat-red    { background: rgba(239,68,68,.1);   color: #fca5a5; border: 1px solid rgba(239,68,68,.2); }
    .tcat-amber  { background: rgba(245,158,11,.1);  color: #fcd34d; border: 1px solid rgba(245,158,11,.2); }
    .tcat-indigo { background: rgba(99,102,241,.1);  color: #a5b4fc; border: 1px solid rgba(99,102,241,.2); }

    .t-title { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 17px; color: var(--text); margin-bottom: 6px; position: relative; z-index: 1; }
    .t-desc { font-size: 13px; color: var(--text-2); line-height: 1.6; margin-bottom: 16px; flex: 1; position: relative; z-index: 1; }

    /* Stats pills */
    .t-stats { display: flex; flex-wrap: wrap; gap: 5px; margin-bottom: 18px; position: relative; z-index: 1; }
    .t-stat { display: flex; align-items: center; gap: 5px; padding: 4px 9px; border-radius: 6px; background: rgba(255,255,255,0.04); border: 1px solid var(--border); font-size: 11.5px; color: var(--text-3); }

    /* Sample data preview */
    .t-preview { background: var(--s3); border-radius: 10px; padding: 10px 12px; margin-bottom: 16px; display: none; position: relative; z-index: 1; animation: fadeUp .25s ease; }
    .t-preview.show { display: block; }
    @keyframes fadeUp { from{opacity:0;transform:translateY(6px)} to{opacity:1;transform:translateY(0)} }
    .tp-label { font-size: 10px; font-weight: 500; color: var(--text-3); text-transform: uppercase; letter-spacing: .05em; margin-bottom: 7px; }
    .tp-row { display: flex; gap: 8px; overflow: hidden; }
    .tp-cell { flex: 1; font-size: 11px; color: var(--text-2); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; min-width: 0; }
    .tp-head { font-size: 10px; color: var(--text-3); font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; flex: 1; min-width: 0; }
    .tp-row-wrap { display: grid; gap: 4px; }
    .tp-data-row { display: flex; gap: 8px; padding: 4px 0; border-bottom: 1px solid rgba(255,255,255,.04); }
    .tp-data-row:last-child { border-bottom: none; }

    /* Action row */
    .t-footer { display: flex; gap: 7px; align-items: center; position: relative; z-index: 1; }
    .t-explore-btn { flex: 1; padding: 11px; border-radius: 10px; border: none; font-family: 'DM Sans', sans-serif; font-size: 13px; font-weight: 500; cursor: pointer; position: relative; overflow: hidden; transition: all .2s; display: flex; align-items: center; justify-content: center; gap: 7px; }
    .t-explore-btn svg { width: 14px; height: 14px; }
    .t-explore-btn .shine { position: absolute; top: 0; left: -100%; width: 55%; height: 100%; background: linear-gradient(90deg, transparent, rgba(255,255,255,.14), transparent); transition: left .6s; }
    .t-explore-btn:hover .shine { left: 160%; }
    .t-explore-btn:hover { transform: translateY(-1px); }
    .teb-blue   { background: linear-gradient(135deg, #3b82f6, #2563eb); color: #fff; box-shadow: 0 4px 14px rgba(59,130,246,.2); }
    .teb-blue:hover   { box-shadow: 0 6px 20px rgba(59,130,246,.3); }
    .teb-purple { background: linear-gradient(135deg, #8b5cf6, #7c3aed); color: #fff; box-shadow: 0 4px 14px rgba(139,92,246,.2); }
    .teb-purple:hover { box-shadow: 0 6px 20px rgba(139,92,246,.3); }
    .teb-green  { background: linear-gradient(135deg, #10b981, #059669); color: #fff; box-shadow: 0 4px 14px rgba(16,185,129,.2); }
    .teb-green:hover  { box-shadow: 0 6px 20px rgba(16,185,129,.3); }
    .teb-red    { background: linear-gradient(135deg, #ef4444, #dc2626); color: #fff; box-shadow: 0 4px 14px rgba(239,68,68,.2); }
    .teb-red:hover    { box-shadow: 0 6px 20px rgba(239,68,68,.3); }
    .teb-amber  { background: linear-gradient(135deg, #f59e0b, #d97706); color: #fff; box-shadow: 0 4px 14px rgba(245,158,11,.2); }
    .teb-amber:hover  { box-shadow: 0 6px 20px rgba(245,158,11,.3); }
    .teb-indigo { background: linear-gradient(135deg, #6366f1, #4f46e5); color: #fff; box-shadow: 0 4px 14px rgba(99,102,241,.2); }
    .teb-indigo:hover { box-shadow: 0 6px 20px rgba(99,102,241,.3); }

    /* Preview toggle */
    .t-peek-btn { width: 38px; height: 38px; border-radius: 9px; background: rgba(255,255,255,.05); border: 1px solid var(--border); color: var(--text-2); cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all .2s; flex-shrink: 0; }
    .t-peek-btn:hover { background: rgba(255,255,255,.09); color: var(--text); }
    .t-peek-btn svg { width: 15px; height: 15px; transition: transform .25s; }
    .t-peek-btn.open svg { transform: rotate(180deg); }

    /* ── No results ── */
    .no-results { grid-column: 1/-1; text-align: center; padding: 56px 24px; background: var(--s2); border: 1px dashed var(--border); border-radius: 18px; }
    .no-results svg { width: 40px; height: 40px; color: var(--text-3); margin: 0 auto 14px; display: block; }
    .no-results h3 { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 17px; color: var(--text); margin-bottom: 6px; }
    .no-results p { font-size: 13px; color: var(--text-3); }

    /* ── Bottom CTA ── */
    .bottom-cta { margin-top: 56px; background: linear-gradient(135deg, rgba(56,189,248,.06), rgba(99,102,241,.05)); border: 1px solid rgba(56,189,248,.15); border-radius: 20px; padding: 40px 36px; text-align: center; position: relative; overflow: hidden; }
    .bottom-cta::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse 60% 60% at 50% 100%, rgba(99,102,241,0.1) 0%, transparent 70%); pointer-events: none; }
    .bottom-cta h3 { font-family: 'Syne', sans-serif; font-weight: 700; font-size: clamp(20px, 2.5vw, 28px); letter-spacing: -.03em; color: var(--text); margin-bottom: 8px; position: relative; }
    .bottom-cta p { font-size: 14px; color: var(--text-2); max-width: 420px; margin: 0 auto 24px; line-height: 1.65; position: relative; font-weight: 300; }
    .cta-btns { display: flex; gap: 10px; justify-content: center; flex-wrap: wrap; position: relative; }
    .cta-primary { padding: 12px 24px; background: linear-gradient(135deg, var(--sky-dark), var(--indigo-mid)); border: none; border-radius: 11px; color: #fff; font-family: 'DM Sans', sans-serif; font-size: 14px; font-weight: 500; cursor: pointer; text-decoration: none; display: inline-flex; align-items: center; gap: 7px; transition: all .2s; box-shadow: 0 4px 18px rgba(14,165,233,0.2); position: relative; overflow: hidden; }
    .cta-primary:hover { opacity: .9; transform: translateY(-2px); box-shadow: 0 8px 24px rgba(14,165,233,0.3); }
    .cta-primary .shine { position: absolute; top: 0; left: -100%; width: 55%; height: 100%; background: linear-gradient(90deg, transparent, rgba(255,255,255,.14), transparent); transition: left .6s; }
    .cta-primary:hover .shine { left: 160%; }
    .cta-ghost { padding: 12px 24px; background: rgba(255,255,255,.04); border: 1px solid var(--border-mid); border-radius: 11px; color: var(--text); font-family: 'DM Sans', sans-serif; font-size: 14px; text-decoration: none; display: inline-flex; align-items: center; gap: 7px; transition: all .2s; }
    .cta-ghost:hover { background: rgba(255,255,255,.08); }

    /* Toast */
    .toast { position: fixed; bottom: 24px; right: 24px; z-index: 400; display: flex; align-items: center; gap: 10px; padding: 12px 16px; border-radius: 11px; font-size: 13px; font-weight: 500; transform: translateY(80px); opacity: 0; transition: all .3s cubic-bezier(.22,1,.36,1); pointer-events: none; }
    .toast.show { transform: translateY(0); opacity: 1; }
    .toast-ok { background: rgba(16,185,129,.12); border: 1px solid rgba(16,185,129,.25); color: #4ade80; }
    .toast svg { width: 14px; height: 14px; flex-shrink: 0; }

    /* Card entrance stagger */
    .t-card { animation: fadeUp .4s ease both; }
    @keyframes fadeUp { from{opacity:0;transform:translateY(14px)} to{opacity:1;transform:translateY(0)} }

    ::-webkit-scrollbar { width: 4px; } ::-webkit-scrollbar-thumb { background: rgba(255,255,255,.08); border-radius: 2px; }
  </style>
</head>
<body>
  <div class="bg-mesh"></div>
  <div class="bg-grid"></div>

  <!-- ── HEADER ── -->
  <header>
    <div class="hdr">
      <a href="/home" class="logo">
        <div class="logo-box"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg></div>
        <span class="logo-name">Viz<span>Chat</span></span>
      </a>
      <div class="hdr-right">
        <a href="/bot_builder" class="btn-sm btn-ghost">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" width="13" height="13"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
          Custom Bot
        </a>
        <a href="/home" class="btn-sm btn-sky">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" width="13" height="13"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
          Home
        </a>
      </div>
    </div>
  </header>

  <!-- ── MAIN ── -->
  <div class="main">

    <!-- Hero -->
    <div class="page-hero">
      <div class="page-eyebrow"><span class="page-eyebrow-dot"></span>Ready-Made Datasets</div>
      <h1 class="page-title">Pick a template,<br><span class="accent">start exploring instantly</span></h1>
      <p class="page-sub">6 real-world datasets — upload in one click, then ask questions using natural language or voice. No setup needed.</p>

      <!-- Filter bar -->
      <div class="filter-bar">
        <div class="search-wrap">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
          <input type="text" class="search-input" id="searchInput" placeholder="Search templates…">
        </div>
        <button class="cat-btn on" data-cat="all">All</button>
        <button class="cat-btn" data-cat="Business">Business</button>
        <button class="cat-btn" data-cat="Education">Education</button>
        <button class="cat-btn" data-cat="Science">Science</button>
        <button class="cat-btn" data-cat="Health">Health</button>
      </div>
    </div>

    <!-- Templates grid -->
    <div class="templates-grid" id="templatesGrid">
      <!-- Rendered by JS -->
    </div>

    <!-- Bottom CTA -->
    <div class="bottom-cta">
      <h3>Got your own data?</h3>
      <p>Upload any CSV, Excel, or JSON file and chat with it in seconds — all running locally on your machine.</p>
      <div class="cta-btns">
        <a href="/bot_builder" class="cta-primary">
          <div class="shine"></div>
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" width="14" height="14"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/></svg>
          Upload My Data
        </a>
        <a href="/assignments" class="cta-ghost">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" width="14" height="14"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          Create Assignment
        </a>
      </div>
    </div>
  </div>

  <!-- Toast -->
  <div class="toast toast-ok" id="toast">
    <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
    <span id="toastMsg">Loading template…</span>
  </div>

<script>
  // ── Template definitions ──────────────────
  const templates = [
